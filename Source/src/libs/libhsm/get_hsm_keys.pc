/** START MAW20050916: Retrieving the AC Key for Cryptogram Verification **/

int Get_AC_Key( int nIndiceCtx, char *sPan, char *sAC_Key)
{
    struct sqlca sqlca;
    char sLine [ MAX_LINE_TRC];

        EXEC SQL BEGIN DECLARE SECTION;
        int              response;
        VARCHAR          T_Pan    [ 22 + 1];
        VARCHAR          T_AC_Key [256 + 1];
        EXEC SQL END DECLARE SECTION;


        EXEC SQL CONTEXT USE :tab_ParamCtx[nIndiceCtx].ctx;

        /*sprintf(sLine, "Start Get_AC_Key(%.16s)", sPan);
        trace_event(sLine, PROCESSING);*/ /** HM - 09022010 - PA_DSS **/
        trace_event("Start Get_AC_Key()", PROCESSING);

        memset( T_Pan.arr,              0, sizeof(T_Pan.arr));
        T_Pan.len = 0;
    
        memset( T_AC_Key.arr,           0, sizeof(T_AC_Key.arr));
        T_AC_Key.len = 0;
    

        memcpy( T_Pan.arr, sPan, strlen(sPan) );
        T_Pan.len = strlen(sPan);
        /*sprintf(sLine, "T_Pan.arr=[%s], T_Pan.len=[%d])", T_Pan.arr, T_Pan.len);
        trace_event(sLine, PROCESSING);*/ /** HM - 09022010 - PA_DSS **/

        response = 909;
        EXEC SQL WHENEVER SQLERROR GOTO sql_exception_tag;
        EXEC SQL EXECUTE
        BEGIN
        :response := PCRD_GET_HSM_KEY_2.GET_AC_KEY (      
                                                          :T_Pan   ,
                                                          :T_AC_Key
                                                   );
        END;
        END-EXEC;

        if (response == OK)
        {
           memcpy(sAC_Key, T_AC_Key.arr, T_AC_Key.len);
           /*sprintf(sLine, "End   Get_AC_Key(%s)", sAC_Key);
           trace_event(sLine, PROCESSING);*/ /** HM - 09022010 - PA_DSS **/
           trace_event("End   Get_AC_Key(OK)", PROCESSING);
           return(OK);
        }

        trace_event("End   Get_AC_Key(NOK)", PROCESSING);
        return(NOK);

    sql_exception_tag :
    EXEC SQL WHENEVER SQLERROR CONTINUE;
    sprintf(sLine, "[%.100s]",sqlca.sqlerrm.sqlerrmc);
    trace_event(sLine, ERROR);
    trace_event("End  Get_AC_Key(MALFUNCTION)", PROCESSING);
    return(HSM_MALFUNCTION);

}

