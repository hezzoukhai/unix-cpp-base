        VARCHAR          T_Pan  [22 + 1];
        char             T_PVKA [16 + 1];
        char             T_PVKB [16 + 1];
        int              T_PVKI;
        EXEC SQL END DECLARE SECTION;


        EXEC SQL CONTEXT USE :tab_ParamCtx[nIndiceCtx].ctx;

        /*sprintf(sLine, "Start GetPVKPinKey(%.16s)", sPan);
        trace_event(sLine, PROCESSING);*/ /** HM - 09022010 - PA_DSS **/
        trace_event("Start GetPVKPinKey()", PROCESSING);

        memset( T_PVKA,         0, sizeof(T_PVKA));
       memset( T_PVKB,         0, sizeof(T_PVKB));
        memset( T_Pan.arr,              0, sizeof(T_Pan.arr));
        T_Pan.len = 22;
    T_PVKI = 0;

        memcpy( T_Pan.arr, sPan, strlen(sPan) );
        T_Pan.len = strlen(sPan);
        /*sprintf(sLine, "T_Pan.arr=[%s], T_Pan.len=[%d])", T_Pan.arr, T_Pan.len);
        trace_event(sLine, PROCESSING);*/ /** HM - 09022010 - PA_DSS **/

        response = 909;
        EXEC SQL WHENEVER SQLERROR GOTO pvk_key_exception;
        EXEC SQL EXECUTE
        BEGIN
        :response := PCRD_GET_HSM_KEY.GET_PVK_KEY (       :T_Pan   ,
                                                                :T_PVKA  ,
                                                                :T_PVKB
                                                        );
        END;
        END-EXEC;

        if (response == OK)
        {
 memcpy(PVKA, T_PVKA, SIZE_KEY );
        memcpy(PVKB, T_PVKB, SIZE_KEY );
        /*sprintf(sLine, "End   GetPVKPinKey(%.16s,%.16s)", PVKA, PVKB);
        trace_event(sLine, PROCESSING);*/ /** HM - 09022010 - PA_DSS **/
        trace_event("End   GetPVKPinKey(OK)", PROCESSING);
        return(OK);
        }

        trace_event("End   GetPVKPinKey(NOK)", PROCESSING);
        return(NOK);

    pvk_key_exception :
    EXEC SQL WHENEVER SQLERROR CONTINUE;
    sprintf(sLine, "%s",sqlca.sqlerrm.sqlerrmc);
    trace_event(sLine, ERROR);
    trace_event("End  GetPVKPinKey(MALFUNCTION)", PROCESSING);
    return(HSM_MALFUNCTION);

}

