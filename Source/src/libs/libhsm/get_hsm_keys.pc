/** BEG YEL05022016: Retrieving the KV Key for Cryptogram Verification **/

int GetKV( int nIndiceCtx, char *sPan, char *sKV)
{
    struct sqlca sqlca;
    char sLine [ MAX_LINE_TRC];

	EXEC SQL BEGIN DECLARE SECTION;
	int              response;
	VARCHAR          T_Pan    [ 22 + 1];
	VARCHAR          T_KV [256 + 1];
	EXEC SQL END DECLARE SECTION;


	EXEC SQL CONTEXT USE :tab_ParamCtx[nIndiceCtx].ctx;

	trace_event("Start GET_KV()", PROCESSING);

	memset( T_Pan.arr,              0, sizeof(T_Pan.arr));
	T_Pan.len = 0;

	memset( T_KV.arr,           0, sizeof(T_KV.arr));
	T_KV.len = 0;

	memcpy( T_Pan.arr, sPan, strlen(sPan) );
	T_Pan.len = strlen(sPan);

	response = 909;
	EXEC SQL WHENEVER SQLERROR GOTO sql_exception_tag;
	EXEC SQL EXECUTE
	BEGIN
	:response := PCRD_GET_HSM_KEY.GET_KV (      
													  :T_Pan   ,
													  :T_KV
											   );
	END;
	END-EXEC;

	if (response == OK)
	{
	   memcpy(sKV, T_KV.arr, T_KV.len);
	   trace_event("End   GET_KV(OK)", PROCESSING);
	   return(OK);
	}

	trace_event("End   GET_KV(NOK)", PROCESSING);
	return(NOK);

    sql_exception_tag :
    EXEC SQL WHENEVER SQLERROR CONTINUE;
    sprintf(sLine, "[%.100s]",sqlca.sqlerrm.sqlerrmc);
    trace_event(sLine, ERROR);
    trace_event("End  GET_KV(MALFUNCTION)", PROCESSING);
    return(HSM_MALFUNCTION);

}

