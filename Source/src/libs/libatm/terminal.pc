/******************************************************************************/
/* Fonction get_terminal_info.                                                */
/* ---------------------------		                                      */
/* Description : Fonction qui recupere les informations concernants un        */
/*		 terminal donne.					      */
/* Entree      : le numero du terminal					      */
/*               le numero du point de service				      */
/*	         la banque acquereur 			 		      */
/*		 le mcc						              */
/*		 le code country				              */
/* Sortie      : OK						              */
/*               NOK                   			                      */
/*               MALFUNCTION                                                  */
/* Date/Auteur : 09/11/1996 Y_KAOUTAR                                         */
/* Revision    :                                                              */
/******************************************************************************/
int    get_terminal_info(
	int			nIndexCtx,
	char		*v_term_nbr,
	char		*v_acqBank,
	char		*v_outlet_nbr,
	char		*v_acquirer_bank,
	int	 		*v_mcc,
	char		*v_country_code,
	char		*v_atm_location,
	int	 		*v_tpk_number)
{

	struct sqlca sqlca;
	char  sLine[MAX_LINE_TRC];

	EXEC SQL BEGIN DECLARE SECTION;
	VARCHAR 		T_term_nbr     [15+1]; 
	varchar      	T_AcqBank  	   [6+1];/*ICH270715*/ 
	VARCHAR 		T_outlet_nbr   [15+1]; 
	char 	  		T_acquirer_bank[ 6+1];
	char      	T_mcc		   [4+1];
	char 	  		T_country_code [ 3+1];
	VARCHAR 		T_atm_location [40+1];
	char      	T_tpk_number   [3+1];
	int	 		response;
	EXEC SQL END DECLARE SECTION;


	sprintf(sLine,"Debut get_terminal_info(%s,%s)", v_term_nbr,v_acqBank/*ICH270715*/ );
	trace_event(sLine, PROCESSING);

	memset(T_term_nbr.arr, 0, sizeof(T_term_nbr.arr));
	memcpy(T_term_nbr.arr, v_term_nbr, strlen((char *)v_term_nbr));
	T_term_nbr.len = strlen((char *)v_term_nbr);

	memset(T_AcqBank.arr, 0, sizeof(T_AcqBank.arr));/*ICH270715*/ 
	memcpy(T_AcqBank.arr, v_acqBank, strlen((char *)v_acqBank));
	T_AcqBank.len = strlen((char *)v_acqBank);

	memset(T_outlet_nbr.arr, 0, sizeof(T_outlet_nbr.arr)); 
	T_outlet_nbr.len = 0;
	memset(T_atm_location.arr, 0 ,sizeof(T_atm_location.arr)); 
	T_atm_location.len = 0;
	memset(T_mcc, 			0, sizeof(T_mcc)); 
	memset(T_country_code,  0, sizeof(T_country_code)); 
	memset(T_acquirer_bank, 0, sizeof(T_acquirer_bank));
	memset(T_tpk_number, 	0, sizeof(T_tpk_number)); 

	response = 909;
	EXEC SQL WHENEVER SQLERROR GOTO terminal_info;
	EXEC SQL CONTEXT USE :tab_ParamCtx[nIndexCtx].ctx;
	EXEC SQL EXECUTE
		DECLARE
		l_term_nbr 		varchar2(15);
	l_outlet_nbr 	varchar2(15);
	l_acquirer_bank char(6);
	l_mcc 			char(4);
	l_country_code 	char(3);
	l_atm_location 	varchar2(40);
	l_tpk_number 	char(3);
	BEGIN
		IF (:T_term_nbr = '##') THEN l_term_nbr := NULL; END IF;


	:response := PCRD_ATM_TOOLS.GET_TERMINAL_INFO( :T_term_nbr, 
		:T_AcqBank/*ICH270715*/ ,
		l_outlet_nbr,
		l_acquirer_bank,
		l_mcc,
		l_country_code,
		l_atm_location,
		l_tpk_number);
	IF (l_outlet_nbr IS NULL) THEN
		:T_outlet_nbr := '      ';
	ELSE
		:T_outlet_nbr := l_outlet_nbr;
	END IF;
	IF (l_acquirer_bank IS NULL) THEN
		:T_acquirer_bank := '      ';
	ELSE
		:T_acquirer_bank := l_acquirer_bank;
	END IF;
	IF (l_mcc IS NULL) THEN
		:T_mcc := '   ';
	ELSE
		:T_mcc := l_mcc;
	END IF;
	IF (l_country_code IS NULL) THEN
		:T_country_code := '  ';
	ELSE
		:T_country_code := l_country_code;
	END IF;
	IF (l_atm_location IS NULL) THEN
		:T_atm_location := '      ';
	ELSE
		:T_atm_location := l_atm_location;
	END IF;
	IF (l_tpk_number IS NULL) THEN
		:T_tpk_number := '  ';
	ELSE
		:T_tpk_number := l_tpk_number;
	END IF;
	END;
	END-EXEC;


	if (response == OK)
	{
		memcpy(v_outlet_nbr   , T_outlet_nbr.arr, T_outlet_nbr.len);
		memcpy(v_country_code , T_country_code  , sizeof(T_country_code));
		memcpy(v_acquirer_bank, T_acquirer_bank , sizeof(T_acquirer_bank));
		memcpy(v_atm_location     , T_atm_location.arr  , T_atm_location.len);
		*v_mcc = atoi(T_mcc);
		*v_tpk_number = atoi(T_tpk_number);


		trace_event("End   get_terminal_info(OK)", PROCESSING);
		return(OK);
	}


	LogEvent(nIndexCtx,
		ResourceId,
		v_term_nbr,
		ERREUR_TRAIT,
		"",
		"", "",
		"", "");

	trace_event("End   get_terminal_info(NOK)", PROCESSING);
	return(NOK);

terminal_info :
	EXEC SQL WHENEVER SQLERROR CONTINUE;
	sprintf(sLine, "%s",sqlca.sqlerrm.sqlerrmc);
	trace_event(sLine, ERROR);
	LogEvent(nIndexCtx,
		ResourceId,
		v_term_nbr,
		ERREUR_TRAIT,
		"",
		"", "",
		"", "");

	trace_event("End  get_terminal_info(MALFUNCTION)", PROCESSING);
	return(MALFUNCTION);
}

int    get_terminal_params(
	int			nIndexCtx,
	char		*v_term_nbr,
	char		*v_acqBank,
	int	 		*v_tz)
{

	struct sqlca sqlca;
	char  sLine[MAX_LINE_TRC];

	EXEC SQL BEGIN DECLARE SECTION;
	VARCHAR 		T_term_nbr     [15+1]; 
	varchar      	T_AcqBank  	   [6+1];
	int      		T_tz;
	int	 			response;
	EXEC SQL END DECLARE SECTION;


	sprintf(sLine,"Start get_terminal_params(%s,%s)", v_term_nbr,v_acqBank );
	trace_event(sLine, PROCESSING);

	memset(T_term_nbr.arr, 0, sizeof(T_term_nbr.arr));
	memcpy(T_term_nbr.arr, v_term_nbr, strlen((char *)v_term_nbr));
	T_term_nbr.len = strlen((char *)v_term_nbr);

	memset(T_AcqBank.arr, 0, sizeof(T_AcqBank.arr));
	memcpy(T_AcqBank.arr, v_acqBank, strlen((char *)v_acqBank));
	T_AcqBank.len = strlen((char *)v_acqBank);

	T_tz = 0;


	response = 909;
	EXEC SQL WHENEVER SQLERROR GOTO terminal_params;
	EXEC SQL CONTEXT USE :tab_ParamCtx[nIndexCtx].ctx;
	EXEC SQL EXECUTE
	BEGIN
		:response := PCRD_ATM_TOOLS.GET_TERMINAL_PARAMS( :T_term_nbr, 
						:T_AcqBank ,
						:T_tz);
	END;
	END-EXEC;


	if (response == OK)
	{
		*v_tz = T_tz;
		sprintf(sLine,"End   get_terminal_params(TZ(%d))",*v_tz);
		trace_event(sLine, PROCESSING);
		return(OK);
	}

	trace_event("End   get_terminal_params(NOK)", PROCESSING);
	return(NOK);

terminal_params :
	EXEC SQL WHENEVER SQLERROR CONTINUE;
	sprintf(sLine, "%s",sqlca.sqlerrm.sqlerrmc);
	trace_event(sLine, ERROR);
	trace_event("End  get_terminal_params(MALFUNCTION)", PROCESSING);
	return(MALFUNCTION);
}

