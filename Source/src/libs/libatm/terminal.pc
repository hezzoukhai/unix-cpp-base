/***********************************************************************
**  nom	: CommsAddToTermNbr()					**
**  desc	: recuperation du numero du terminal a partir de son	**
**		adresse telecom						**
**  entree	: pCallingAdd	-> adresse de l'appelant		**
**  sortie	: pTermNbr	-> numero du terminal			**
**  retour	: OK	-> la fonction arrive a recuperer le numero du	**
**		terminal						**
**		  NOK	-> pas de terminal avec l'adresse indiquee	**
**		  ERROR	-> erreur fatale				**
**  creation	: 26 Jan 1999						**
***********************************************************************/
int CommsAddToTermNbr(
	int		nIndexCtx,
	char	*pCallingAdd,
	char	*pTermNbr,
	char	*pExternalId,
	char	*pAcqBank)/*ICH270715*/
{
	struct sqlca sqlca;
	char  sLine[MAX_LINE_TRC];
	EXEC SQL BEGIN DECLARE SECTION;
	varchar		hCallingAdd		[15+1];
	varchar		hTermNbr		[15+1];
	varchar		hTExternalId	[15+1];
	varchar		hAcqBank		[6];/*ICH270715*/
	
	short       pl_null_ExternalId_ind ; 
			
	int			hResponseCode;
	
	EXEC SQL END DECLARE SECTION;

	sprintf(sLine, "Start CommsAddToTermNbr(%.15s)", pCallingAdd);
	trace_event(sLine, PROCESSING);

	/* - memset et initialisation ------------------------------------------- */
	memset(hCallingAdd.arr,	0, sizeof(hCallingAdd.arr));
	hCallingAdd.len	= 0;
	memset(hTermNbr.arr,	0, sizeof(hTermNbr.arr));
	hTermNbr.len	= 0;
	memset(hTExternalId.arr,	0, sizeof(hTExternalId.arr));
	hTExternalId.len	= 0;
	memset(hAcqBank.arr,	0, sizeof(hAcqBank.arr));/*ICH270715*/
	hAcqBank.len        = 0;


	memcpy(hCallingAdd.arr,	pCallingAdd, strlen(pCallingAdd));
	hCallingAdd.len = strlen(pCallingAdd);


	/* - capture des exceptions --------------------------------------------- */
	EXEC SQL WHENEVER SQLERROR GOTO commsAddToTermNbrErr;
	EXEC SQL CONTEXT USE :tab_ParamCtx[nIndexCtx].ctx;


	/* - appel de la fonction PL/SQL ---------------------------------------- */

	EXEC SQL EXECUTE
		BEGIN
		:hResponseCode := PCRD_ATM_TERMINAL.COMMSADD_TO_TERMNBR(
		:hCallingAdd,
		:hTermNbr,
		:hTExternalId:pl_null_ExternalId_ind,
		:hAcqBank/*ICH270715*/);
	END;
	END-EXEC;


	/* - examen du retour de la fonction PL/SQL ----------------------------- */
	if(hResponseCode != OK)
	{
		trace_event("End   CommsAddToTermNbr(NOK)", PROCESSING);
		return (hResponseCode);
	}


	/* - recuperation du resultat de la fonction PL/SQL --------------------- */
	memcpy(pTermNbr, hTermNbr.arr, hTermNbr.len);pTermNbr[hTermNbr.len]='\0';
	
	if( -1 != pl_null_ExternalId_ind )
	{
		memcpy(pExternalId, hTExternalId.arr, hTExternalId.len);pExternalId[hTExternalId.len]='\0';

	}
	memcpy(pAcqBank, hAcqBank.arr, hAcqBank.len);pAcqBank[hAcqBank.len]='\0'; /*ICH270715*/

	sprintf(sLine, "End   CommsAddToTermNbr(%.15s,%.6s,%.15s)", pTermNbr,pAcqBank,pExternalId);
	trace_event(sLine, PROCESSING);
	return (OK);

commsAddToTermNbrErr :
	sprintf(sLine, "%.79s", sqlca.sqlerrm.sqlerrmc);
	trace_event(sLine, ERROR);
	trace_event("End   CommsAddToTermNbr(ERROR)", ERROR);
	return (ERROR);
}


