/***********************************************************************
**  nom		: cassette_fault                                      **
**  desc   	: mis a jour le status de la cassette pK7Denom        **	
************************************************************************/

int   cassette_fault(int nIndexCtx, char *V_terminal_number,char *V_AcqBank /*ICH270715*/, char *pK7Denom, char *pK7DenomStatus) {
	struct sqlca sqlca;
	char sLine [ MAX_LINE_TRC];

   	EXEC SQL BEGIN DECLARE SECTION;
        	VARCHAR         T_terminal_number[15];
        VARCHAR      			T_AcqBank  	 	[6+1];/*ICH270715*/ 
		char            hK7Denom[1 + 1];
		char            hK7Status[1 + 1];
		int		retour;
   	EXEC SQL END DECLARE SECTION;

	sprintf(sLine, "Start cassette_fault(%s,%s,%s,%s)", V_terminal_number,V_AcqBank, pK7Denom, pK7DenomStatus);
   	trace_event(sLine, PROCESSING);

   	memset(T_terminal_number.arr, 0, sizeof(T_terminal_number.arr));
	memset(T_AcqBank.arr,	0, sizeof(T_AcqBank.arr));/*ICH270715*/     
	memset(hK7Denom, 0, sizeof(hK7Denom));
	memset(hK7Status, 0, sizeof(hK7Status));

   	memcpy(T_terminal_number.arr, V_terminal_number, strlen(V_terminal_number));
   	T_terminal_number.len = strlen(V_terminal_number);

	memcpy(T_AcqBank.arr, V_AcqBank, strlen(V_AcqBank));
	T_AcqBank.len = strlen(V_AcqBank);
	
	memcpy(hK7Denom, pK7Denom, 1);
	memcpy(hK7Status, pK7DenomStatus, 1);


   	EXEC SQL CONTEXT USE :tab_ParamCtx[nIndexCtx].ctx;
   	EXEC SQL WHENEVER SQLERROR  GOTO cassette_fault_error;
   	EXEC SQL EXECUTE
   	BEGIN
        	/*:retour := PCRD_ATM_TOOLS.CASSETTE_FAULT(:T_terminal_number,:T_AcqBank,'N');*/
		:retour := PCRD_DBL_CASSETTE_MNG_1.UPDATE_DENOM_STATUS(:T_terminal_number,:T_AcqBank/*ICH270715*/,  :hK7Status, UPPER(:hK7Denom));

		IF :retour = 0  OR :retour = 898 THEN    
			COMMIT;
		ELSE
			ROLLBACK;
		END IF;

   	END;
	END-EXEC;

	if (retour == OK) {
		trace_event("End   cassette_fault(OK) ",PROCESSING);
		return(OK);
	} else {
		if (retour == 898) {
			trace_event("End   cassette_fault(OUT_SERVICE) ",PROCESSING);
			return(OUT_SERVICE);
		} else {
			trace_event("End   cassette_fault(NOK) ",PROCESSING);
			return(NOK);
		}
	}

	cassette_fault_error   :
   		EXEC SQL WHENEVER SQLERROR CONTINUE;
   		sprintf(sLine, "%s",sqlca.sqlerrm.sqlerrmc);
   		trace_event(sLine, ERROR);
   		trace_event("End   cassette_fault(NOK) ",PROCESSING);
   		return(NOK);
}


