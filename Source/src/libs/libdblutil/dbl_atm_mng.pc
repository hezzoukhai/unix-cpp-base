   trace_event(sLine, ERROR);
   trace_event("End   ticket_printer_stat(NOK) ",PROCESSING);
   return(NOK);
}

int     log_printer_stat(int nIndexCtx ,char *V_terminal_number,char *V_AcqBank, char *V_status)
{
    struct sqlca sqlca;
    char sLine[MAX_LINE_TRC];

    EXEC SQL BEGIN DECLARE SECTION;
        VARCHAR         T_terminal_number       [15];
        VARCHAR      		T_AcqBank  	 	        [6+1];/*ICH270715*/ 
        char            T_printer_status        [ 1+1];
		int				retour;
    EXEC SQL END DECLARE SECTION;

    sprintf(sLine, "Start log_printer_stat(%d,%s,%s,%s)",nIndexCtx,V_terminal_number,V_AcqBank, V_status);
    trace_event(sLine, PROCESSING);

    memset(T_terminal_number.arr, 0, sizeof(T_terminal_number.arr));
	memset(T_AcqBank.arr,	0, sizeof(T_AcqBank.arr));/*ICH270715*/     
    memset(T_printer_status, 0, sizeof(T_printer_status));

    memcpy(T_terminal_number.arr, V_terminal_number, strlen(V_terminal_number));
    T_terminal_number.len = strlen((char *)V_terminal_number);

	memcpy(T_AcqBank.arr, V_AcqBank, strlen(V_AcqBank));
	T_AcqBank.len = strlen(V_AcqBank);

    memcpy(T_printer_status, V_status, 1);


    EXEC SQL WHENEVER SQLERROR  GOTO log_printer_stat_error;
    EXEC SQL CONTEXT USE :tab_ParamCtx[nIndexCtx].ctx;
    EXEC SQL EXECUTE
    BEGIN
        :retour := PCRD_ATM_TOOLS.LOG_PRINTER_FAULT(:T_terminal_number,:T_AcqBank/*ICH270715*/,:T_printer_status);
    END;
    END-EXEC;
    trace_event("End   log_printer_stat(OK) ",PROCESSING);
    return(OK);

log_printer_stat_error  :
    EXEC SQL WHENEVER SQLERROR CONTINUE;
    sprintf(sLine, "%s",sqlca.sqlerrm.sqlerrmc);
    trace_event(sLine, ERROR);
    trace_event("End   log_printer_stat(NOK) ",PROCESSING);
    return(NOK);
}


  /***********************************************************************
  **  nom       : GetReceiptStatus()                                    **
  **  desc      : Traitement de l'information concernant le Ticket print
  **  entree    : status field                                          **
  **  sortie    :                                                       **
  **  retour    : status de l'operation                                 **
  **  auteur    : Bellamine Faycal                                      **
  ***********************************************************************/
int     GetReceiptStatus(nIndexCtx, pDBLBufferIn, pDBLBufferLen, Terminal_Number)
	int	nIndexCtx;
	char   *pDBLBufferIn;
	int     pDBLBufferLen;
	char    *Terminal_Number;
{

 int   lRet;
 int   lCpt = 0;
 char  lData[256];
 char  lStatus[256];
 char  lStatusDescriptor[3];
 char  sLine[MAX_LINE_TRC];
  struct sqlca sqlca;

EXEC SQL BEGIN DECLARE SECTION;
        char            hTicketPrinterStatus[ 1 + 1];
        varchar         hTerminal           [15 + 1];
EXEC SQL END DECLARE SECTION;


 sprintf(sLine, "Start   GetReceiptStatus(%.15s) ", Terminal_Number);
 trace_event(sLine, PROCESSING);
 
 memset(lData,                  0,sizeof(lData)                 );
 memset(lStatusDescriptor,      0,            3     );
 memset(hTerminal.arr,          0,sizeof(hTerminal.arr)             );
 memset(hTicketPrinterStatus,   0,sizeof(hTicketPrinterStatus)  );

 memcpy(hTerminal.arr,Terminal_Number,strlen(Terminal_Number     )  );
 hTerminal.len = strlen(Terminal_Number);

 Download_Field(pDBLBufferIn,    3,      lStatusDescriptor,    pDBLBufferLen);
 Download_Field(pDBLBufferIn,    4,      lData,                pDBLBufferLen);
 
 if(lStatusDescriptor[0] == '8')
 {
 while( lCpt < strlen(lData) )
  {
   lRet = GetDBLField(lData,strlen(lData),1,GS,lStatus);
   if(lStatus[0] == 'B')break;
   lCpt++;
  }

 if(lRet != OK)
  {
   trace_event("End   GetReceiptStatus(Error) ",PROCESSING);
   return(lRet);
  }

 if(lStatus[18] & 0x08)   
  {
    hTicketPrinterStatus[0] = 'I';
    tab_DblCtx[nIndexCtx].gSystem.fTrnInPrgFlg = OK;
  }
 else
  {
    hTicketPrinterStatus[0] = 'O';
    tab_DblCtx[nIndexCtx].gSystem.fTrnInPrgFlg = NOK;
  }


 EXEC SQL WHENEVER SQLERROR  GOTO GetReceiptStatus_error;
 EXEC SQL CONTEXT USE :tab_ParamCtx[nIndexCtx].ctx;
 EXEC SQL UPDATE TERMINAL_ATM_WATCH_WARNING
 SET   ticket_printer_status    = :hTicketPrinterStatus
 WHERE terminal_atm_number          = :hTerminal;
 EXEC SQL COMMIT;

 }

 trace_event("End   GetReceiptStatus(OK) ",PROCESSING);
 return(OK);
 GetReceiptStatus_error :
    sprintf(sLine, "%.79s", sqlca.sqlerrm.sqlerrmc);
    trace_event(sLine, ERROR);
    trace_event("End   GetReceiptStatus(ERROR)", PROCESSING);
    return (ERROR);
}

/*BEGIN AHM 07/09/2005*/


/***********************************************************************
**  nom       : UpdateHardwareStatus                                  **
**  desc      : Met a jour les status des pheripherique               ** 
**  entree    : status field                                          **
**  sortie    :                                                       **
**  retour    : status de l'operation                                 **
**  auteur    : Adil HMAMI                                            **
***********************************************************************/
int     UpdateHardwareStatus(nIndexCtx, pHardawareSatusIn, pHardawareSatusLen)
	int	nIndexCtx;
	char*	pHardawareSatusIn;
	int	pHardawareSatusLen;
{

	int	nIndex = nIndexCtx - RESERVED_THREAD;
 	int   	lRet;
 	char  	lStatus[256];
 	char  	lStatusDescriptor[3];
 	char  	sLine[MAX_LINE_TRC];
	struct sqlca sqlca;

 	sprintf(sLine, "Start UpdateHardwareStatus" );
 	trace_event(sLine, PROCESSING);
 	
	/*la longuer de ce champs doit etre superiere a 17: byte 'B' + ((8 byte de standard hardware) *2 ) */
	if (pHardawareSatusLen < 17) {
		sprintf(sLine, "End   UpdateHardwareStatus(NOK)" );
		trace_event(sLine, PROCESSING);
		return NOK;
	}

	/*Verifier que les bits reserves ont les bonnes valeurs*/
	/*if (	pHardawareSatusIn[3] & 0x01	|| pHardawareSatusIn[4] & 0x04
						|| pHardawareSatusIn[5] & 0x12				
						|| !(pHardawareSatusIn[6] & 0x02)
						|| pHardawareSatusIn[7] & 0x15				
						|| pHardawareSatusIn[8] & 0x15			
						|| pHardawareSatusIn[9] & 0x15				
						|| pHardawareSatusIn[10] & 0x15				
						|| pHardawareSatusIn[11] & 0x14				
						|| pHardawareSatusIn[12] & 0x14				
						|| pHardawareSatusIn[13] & 0x15				
						|| pHardawareSatusIn[14] & 0x15				
						|| !(pHardawareSatusIn[15] & 0x08))  {
	        sprintf(sLine, "End   UpdateHardwareStatus(NOK,reserverd bits)" );    
                trace_event(sLine, PROCESSING);
	return NOK;
	}*/

	/*Mise a jour du status du Journal Printer*/
	sprintf(sLine, "Debug HardawareSatus=[%c]", pHardawareSatusIn[6]);
	trace_event(sLine, PROCESSING);
	if (pHardawareSatusIn[6] & 0x08) {
		log_printer_stat(nIndexCtx, tab_DblCtx[nIndex].terminal,tab_DblCtx[nIndex].AcquirerBank/*ICH270715*/ , "I");
	} else {
		log_printer_stat(nIndexCtx, tab_DblCtx[nIndex].terminal,tab_DblCtx[nIndex].AcquirerBank/*ICH270715*/ , "O");
	}

	/*Mise a jour du status du Card Reader */
	sprintf(sLine, "Debug HardawareSatus=[%c]", pHardawareSatusIn[6]);
	trace_event(sLine, PROCESSING);
	if (pHardawareSatusIn[6] & 0x04) {
		card_reader_stat(nIndexCtx, tab_DblCtx[nIndex].terminal,tab_DblCtx[nIndex].AcquirerBank/*ICH270715*/, "I");	
	} else {
		card_reader_stat(nIndexCtx, tab_DblCtx[nIndex].terminal,tab_DblCtx[nIndex].AcquirerBank/*ICH270715*/, "O");	
	}

	/*Mise a jour du status du Cunsomer Printer*/
	sprintf(sLine, "Debug HardawareSatus=[%c]", pHardawareSatusIn[16]);
	trace_event(sLine, PROCESSING);
	if (pHardawareSatusIn[16] & 0x08) {
		ticket_printer_stat(nIndexCtx, tab_DblCtx[nIndex].terminal,tab_DblCtx[nIndex].AcquirerBank/*ICH270715*/, "I");	
	} else {
		ticket_printer_stat(nIndexCtx, tab_DblCtx[nIndex].terminal,tab_DblCtx[nIndex].AcquirerBank/*ICH270715*/, "O");	
	}

	sprintf(sLine, "End   UpdateHardwareStatus(OK)" );
	trace_event(sLine, PROCESSING);
	return OK;
}
/*END AHM*/
