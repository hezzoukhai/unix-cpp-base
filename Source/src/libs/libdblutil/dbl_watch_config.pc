  /***********************************************************************
  **  nom	: GetATMMngCmd()					**
  **  desc	: chargement de la commande pour le GAB			**
  **  entree	: fTerminalNumber	-> numero du terminal		**
  **  sortie	: fCommand		-> commande pour le terminal	**
  **		  fPurgeDate		-> date d'expiration de la cmd	**
  **  retour	: OK	-> si c'est OK					**
  **		  ERROR	-> erreur fatal					**
  **			(c) 1999 Hightech Payment Systems		**
  ***********************************************************************/
int	GetATMMngCmd(nIndexCtx,pATMCommand)
int 		nIndexCtx;
atm_command	*pATMCommand;
{
   char  sLine[MAX_LINE_TRC];
EXEC SQL BEGIN DECLARE SECTION;
    varchar		hTermNbr	[15+1];
    varchar		hAcqBank	[6+1];/*ICH270715*/ 
    int			hCmdSeq;
    varchar		hCmd		[30+1];
    char		hPurgeDate	[12+1];
    int			hRet;
EXEC SQL END DECLARE SECTION;

sprintf(sLine, "Start GetATMMngCmd(%.15s,%.6s)", pATMCommand->fTerminalNumber, pATMCommand->fAcqBank/*ICH270715*/);

trace_event(sLine, PROCESSING);

    /* - initilialisation des variables ------------------------------------- */
    memset(pATMCommand->fPurgeDate,	0, sizeof(pATMCommand->fPurgeDate));
    memset(pATMCommand->fCommand,	0, sizeof(pATMCommand->fCommand)  );
    memset(hTermNbr.arr,		0, sizeof(hTermNbr.arr)		  );
    memset(hAcqBank.arr,		0, sizeof(hAcqBank.arr));/*ICH270715*/     
    memset(hCmd.arr,			0, sizeof(hCmd.arr)		  );
    memset(hPurgeDate,			0, sizeof(hPurgeDate)		  );
    hTermNbr.len	= sizeof(hTermNbr.arr);
    hAcqBank.len	= sizeof(hAcqBank.arr);/*ICH270715*/  
    hCmd.len		= sizeof(hCmd.arr);

    /* - renseignement des variables PL/SQL --------------------------------- */
    memcpy(hTermNbr.arr,pATMCommand->fTerminalNumber,
			strlen(pATMCommand->fTerminalNumber));
    hTermNbr.len	= strlen(pATMCommand->fTerminalNumber);

    memcpy(hAcqBank.arr,	pATMCommand->fAcqBank, strlen(pATMCommand->fAcqBank));/*ICH270715*/
	hAcqBank.len	= strlen(pATMCommand->fAcqBank);
	
    /* - capture des exceptions PL/SQL -------------------------------------- */
    EXEC SQL CONTEXT USE :tab_ParamCtx[nIndexCtx].ctx;
    EXEC SQL WHENEVER SQLERROR GOTO getUserCommandErr;

    /* - execution du traitement PL/SQL ------------------------------------- */
    EXEC SQL EXECUTE
    DECLARE
        enr_atm_commands	ATM_COMMANDS%ROWTYPE;
    BEGIN
        -- preparation de l'enregistrement
        enr_atm_commands.terminal_number := :hTermNbr;
        enr_atm_commands.bank_code		 := :hAcqBank;/*ICH270715*/

        -- execution du PL/SQL
        :hRet := PCRD_ATM_MNG.GET_ATM_CMD(enr_atm_commands);

        -- recuperation du resultat
        IF :hRet = DECLARATION_CST.OK
        THEN
            :hCmd	:=enr_atm_commands.command;
            :hCmdSeq	:=enr_atm_commands.cmd_seq;
            :hPurgeDate :=TO_CHAR(enr_atm_commands.purge_date,'YYMMDDHH24MISS');
        END IF;
    END;
    END-EXEC;

    /* - examen du retour du traitement PL/SQL ------------------------------ */
    if (hRet != OK)
    {
        sprintf(sLine, "End   GetATMMngCmd(%d)", hRet);
        trace_event(sLine, PROCESSING);
        return (hRet);
    }

    /* - recuperation du resultat du traitement PL/SQL ---------------------- */
    memcpy(pATMCommand->fCommand,	hCmd.arr,	hCmd.len);
    memcpy(pATMCommand->fPurgeDate,	hPurgeDate,	      12);
    pATMCommand->fCmdSeq		= hCmdSeq;

sprintf(sLine, "End   GetATMMngCmd(%d,%.30s,%.12s)",
                 pATMCommand->fCmdSeq,
                 pATMCommand->fCommand,
                 pATMCommand->fPurgeDate);
trace_event(sLine, PROCESSING);
return (OK);

getUserCommandErr:
    sprintf(sLine, "%.79s", sqlca.sqlerrm.sqlerrmc);
    trace_event(sLine, ERROR);
    trace_event("End   GetATMMngCmd(ERROR)", ERROR);
    return (ERROR);
}

  /***********************************************************************
  **  nom	: PutATMMngCmdRes()					**
  **  desc	: avis a la table ATM_COMMANDS				**
  **  entree	: fTerminalNumber	-> numero du terminal		**
  **  sortie	: fCommand		-> commande pour le terminal	**
  **  retour	: OK	-> si c'est OK					**
  **		  ERROR	-> erreur fatal					**
  **  auteur	: Younes OUADI (02 Avr 1999)				**
  **			(c) 1999 Hightech Payment Systems		**
  ***********************************************************************/
int	PutATMMngCmdRes(nIndexCtx,pATMCommand)
int 		nIndexCtx;
atm_command	pATMCommand;
{
   char  sLine[MAX_LINE_TRC];
EXEC SQL BEGIN DECLARE SECTION;
    varchar		hTermNbr	[15+1];
    varchar		hAcqBank	[6+1];/*ICH270715*/ 
    int			hCmdSeq;
    varchar		hCmd		[30+1];
    char		hPurgeDate	[12+1];
    char		hStatus		[ 1+1];
    int			hRet;
EXEC SQL END DECLARE SECTION;

sprintf(sLine, "Start PutATMMngCmdRes(%.15s,%.6s,%d,%.30s,%.12s,%.1s)",
                pATMCommand.fTerminalNumber,
                pATMCommand.fAcqBank,/*ICH270715*/
                pATMCommand.fCmdSeq,
                pATMCommand.fCommand,
                pATMCommand.fPurgeDate,
                pATMCommand.fStatus);
trace_event(sLine, PROCESSING);

    /* - initilialisation des variables ------------------------------------- */
    memset(hTermNbr.arr,		0, sizeof(hTermNbr.arr)		);
    memset(hAcqBank.arr,		0, sizeof(hAcqBank.arr));/*ICH270715*/     
    memset(hCmd.arr,			0, sizeof(hCmd.arr)		);
    memset(hPurgeDate,			0, sizeof(hPurgeDate)		);
    memset(hStatus,				0, sizeof(hStatus)		);

    /* - renseignement des variables PL/SQL --------------------------------- */
    memcpy(hTermNbr.arr,pATMCommand.fTerminalNumber,
			strlen(pATMCommand.fTerminalNumber));
    hTermNbr.len	= strlen(pATMCommand.fTerminalNumber);
    
    memcpy(hAcqBank.arr,	pATMCommand.fAcqBank, strlen(pATMCommand.fAcqBank));/*ICH270715*/
	hAcqBank.len	= strlen(pATMCommand.fAcqBank);
    
    memcpy(hCmd.arr,	pATMCommand.fCommand,
			strlen(pATMCommand.fCommand));
    hCmd.len		= strlen(pATMCommand.fCommand);
    memcpy(hPurgeDate,	pATMCommand.fPurgeDate,
			strlen(pATMCommand.fPurgeDate));
    memcpy(hStatus,	pATMCommand.fStatus, 1);
    hCmdSeq		= pATMCommand.fCmdSeq;


    /* - capture des exceptions PL/SQL -------------------------------------- */
    EXEC SQL WHENEVER SQLERROR GOTO getUserCommandErr;
    EXEC SQL CONTEXT USE :tab_ParamCtx[nIndexCtx].ctx;

    /* - execution du traitement PL/SQL ------------------------------------- */

    EXEC SQL EXECUTE
    DECLARE
        enr_atm_commands	ATM_COMMANDS%ROWTYPE;
    BEGIN
        -- preparation de l'enregistrement
        enr_atm_commands.terminal_number	:= :hTermNbr;
        enr_atm_commands.bank_code		:= :hAcqBank;/*ICH270715*/
        enr_atm_commands.cmd_seq		:= :hCmdSeq;
        enr_atm_commands.command		:= :hCmd;
        enr_atm_commands.purge_date		:= TO_DATE(:hPurgeDate,'YYMMDDHH24MISS');
        enr_atm_commands.status			:= :hStatus;

        -- execution du PL/SQL
        :hRet := PCRD_ATM_MNG.PUT_ATM_CMD_RES(enr_atm_commands);
    END;
    END-EXEC;


    /* - examen du retour du traitement PL/SQL ------------------------------ */
    if (hRet != OK)
    {
        sprintf(sLine, "End   PutATMMngCmdRes(%d)", hRet);
        trace_event(sLine, PROCESSING);
        return (hRet);
    }

sprintf(sLine, "End   PutATMMngCmdRes(%s)", pATMCommand.fCommand);
trace_event(sLine, PROCESSING);
return (OK);

getUserCommandErr:
    sprintf(sLine, "%.79s", sqlca.sqlerrm.sqlerrmc);
    trace_event(sLine, ERROR);
    trace_event("End   PutATMMngCmdRes(ERROR)", ERROR);
    return (ERROR);
}

