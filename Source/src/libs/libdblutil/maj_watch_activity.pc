char		sLine	[80];
EXEC SQL BEGIN DECLARE SECTION;
    VARCHAR		hTerminal	[15 + 1];
    VARCHAR		hAcqBank	[6+1];/*ICH270715*/ 
    char		hTrnDate	[12 + 1];
    char		hTrsDate	[10 + 1];
    int			hRetour;
EXEC SQL END DECLARE SECTION;

sprintf(sLine, "Start IncChequeReq(%.15s,%.6s,%.12s,%.10s)",
        pTerminal,pAcqBank/*ICH270715*/,pTrnDate,pTrsDate);
trace_event(sLine, PROCESSING);

    /* - memset des buffer ---------------------------------------------- */
    memset(hTerminal.arr,	0, sizeof(hTerminal.arr));
    memset(hAcqBank.arr,	0, sizeof(hAcqBank.arr));/*ICH270715*/     
    memset(hTrnDate,		0, sizeof(hTrnDate)	);
    memset(hTrsDate,		0, sizeof(hTrsDate)	);


    /* - initialisation des variables ----------------------------------- */
    memcpy(hTerminal.arr,	pTerminal, strlen(pTerminal));
    hTerminal.len	= strlen(pTerminal);

 	memcpy(hAcqBank.arr,	pAcqBank, strlen(pAcqBank));/*ICH270715*/
	hAcqBank.len	= strlen(pAcqBank);
	

    memcpy(hTrnDate,		pTrnDate, strlen(pTrnDate));

    memcpy(hTrsDate,		pTrsDate, strlen(pTrsDate));


    /* - capture des exceptions ------------------------------------------ */
    EXEC SQL WHENEVER SQLERROR GOTO incChequeReqErr;
    EXEC SQL CONTEXT USE :tab_ParamCtx[nIndexCtx].ctx;

    /* - traitement PL/SQL ----------------------------------------------- */
    EXEC SQL EXECUTE
      BEGIN
        :hRetour := PCRD_ATM_ACTIVITY.INC_CHEQUE_REQ(  :hTerminal,
                    :hAcqBank,/*ICH270715*/       
					TO_DATE(:hTrnDate, 'YYMMDDHH24MISS'),
					TO_DATE(:hTrsDate, 'MMDDHH24MISS'));
      END;
    END-EXEC;

    if(hRetour != OK)
    {
        sprintf(sLine, "End   IncChequeReq(NOK)");
        trace_event(sLine, PROCESSING);
        return (NOK);
    }

sprintf(sLine, "End   IncChequeReq(OK)");
trace_event(sLine, PROCESSING);
return (OK);

incChequeReqErr :
    sprintf(sLine, "%.79s", sqlca.sqlerrm.sqlerrmc);
    trace_event(sLine, ERROR);
    trace_event("End   IncChequeReq(ERROR)", ERROR);
    return (ERROR);
}


  /***********************************************************************
  **  nom	: IncCardReq()						**
  **  desc	: maj des demandes de carte dans watch_activity		**
  **  entree	: pTerminal	-> numero du terminal			**
  **		  pTrnDate	-> date de la transaction		**
  **		  pTrsDate	-> dete de la transmission		**
  **  sortie	: aucun							**
  **  retour	: OK	-> si c'est OK					**
  **		  NOK	-> erreur PL/SQL				**
  **		  ERROR	-> erreur fatal					**
  **  auteur	: Younes OUADI (19 Dec 1998)				**
  ***********************************************************************/
int	IncCardReq(nIndexCtx,pTerminal, pAcqBank /*ICH270715*/, pTrnDate, pTrsDate)
int			nIndexCtx;
char		pTerminal	[16];
char		pAcqBank	[6+1];/*ICH270715*/
char		pTrnDate	[13];
char		pTrsDate	[11];
{
struct sqlca sqlca;
char		sLine	[80];
EXEC SQL BEGIN DECLARE SECTION;
    VARCHAR		hTerminal	[15 + 1];
    VARCHAR		hAcqBank	[6+1];/*ICH270715*/ 
    char		hTrnDate	[12 + 1];
    char		hTrsDate	[10 + 1];
    int			hRetour;
EXEC SQL END DECLARE SECTION;

sprintf(sLine, "Start IncCardReq(%.15s,%.6s,%.12s,%.10s)",
        pTerminal,pAcqBank/*ICH270715*/,pTrnDate,pTrsDate);
trace_event(sLine, PROCESSING);

    /* - memset des buffer ---------------------------------------------- */
    memset(hTerminal.arr,	0, sizeof(hTerminal.arr));
    memset(hAcqBank.arr,	0, sizeof(hAcqBank.arr));/*ICH270715*/     
    memset(hTrnDate,		0, sizeof(hTrnDate)	);
    memset(hTrsDate,		0, sizeof(hTrsDate)	);


    /* - initialisation des variables ----------------------------------- */
    memcpy(hTerminal.arr,	pTerminal, strlen(pTerminal));
    hTerminal.len	= strlen(pTerminal);

 	memcpy(hAcqBank.arr,	pAcqBank, strlen(pAcqBank));/*ICH270715*/
	hAcqBank.len	= strlen(pAcqBank);
	
    memcpy(hTrnDate,		pTrnDate, strlen(pTrnDate));

    memcpy(hTrsDate,		pTrsDate, strlen(pTrsDate));


    /* - capture des exceptions ------------------------------------------ */
    EXEC SQL WHENEVER SQLERROR GOTO incCardReqErr;
    EXEC SQL CONTEXT USE :tab_ParamCtx[nIndexCtx].ctx;

    /* - traitement PL/SQL ----------------------------------------------- */
    EXEC SQL EXECUTE
      BEGIN
        :hRetour := PCRD_ATM_ACTIVITY.INC_CARD_REQ(  :hTerminal,
                    :hAcqBank,/*ICH270715*/       
					TO_DATE(:hTrnDate, 'YYMMDDHH24MISS'),
					TO_DATE(:hTrsDate, 'MMDDHH24MISS'));
      END;
    END-EXEC;

    if(hRetour != OK)
    {
        sprintf(sLine, "End   IncCardReq(NOK)");
        trace_event(sLine, PROCESSING);
        return (NOK);
    }

sprintf(sLine, "End   IncCardReq(OK)");
trace_event(sLine, PROCESSING);
return (OK);

incCardReqErr :
    sprintf(sLine, "%.79s", sqlca.sqlerrm.sqlerrmc);
    trace_event(sLine, ERROR);
    trace_event("End   IncCardReq(ERROR)", ERROR);
    return (ERROR);
}


