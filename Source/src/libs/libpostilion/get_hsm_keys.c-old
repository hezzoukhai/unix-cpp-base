{

    struct sqlca sqlca;
    char sLine [ MAX_LINE_TRC];

	/* EXEC SQL BEGIN DECLARE SECTION; */ 

        int              response;
        /* VARCHAR          T_terminal_nbr     [15 + 1]; */ 
struct { unsigned short len; unsigned char arr[16]; } T_terminal_nbr;

        /* varchar             T_BDK1          [256 + 1]; */ 
struct { unsigned short len; unsigned char arr[257]; } T_BDK1;

	/* EXEC SQL END DECLARE SECTION; */ 


	/* EXEC SQL CONTEXT USE :tab_ParamCtx[nIndiceCtx].ctx; */ 

	sprintf(sLine, "Start GetBDK(%.15s)", terminal_nbr);
	trace_event(sLine, PROCESSING);

	memset(T_BDK1.arr,         		0, sizeof(T_BDK1.arr));
	memset(T_terminal_nbr.arr, 	0, sizeof(T_terminal_nbr.arr));

	memcpy(T_terminal_nbr.arr, terminal_nbr, strlen(terminal_nbr));
	T_terminal_nbr.len = strlen(terminal_nbr);


	response = HSM_MALFUNCTION;
	/* EXEC SQL WHENEVER SQLERROR GOTO bdk_key_exception; */ 

	/* EXEC SQL EXECUTE
	BEGIN
        :response := PCRD_POS_DUKPT_KEY_MNG.GET_BDK_KEY(:T_terminal_nbr,
                                                        :T_BDK1
                                                       );
	END;
