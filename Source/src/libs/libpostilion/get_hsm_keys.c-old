/** **/

int Get_EMV_Key( int nIndexCtx, char *sPan, char *sKeyCode, char *sEmvKey)
{
    struct sqlca sqlca;
    char sLine [ MAX_LINE_TRC];

        /* EXEC SQL BEGIN DECLARE SECTION; */ 

        int              response;
        /* VARCHAR          T_Pan         [ 22 + 1]; */ 
struct { unsigned short len; unsigned char arr[23]; } T_Pan;

        /* VARCHAR          T_KeyCode     [ 4 + 1]; */ 
struct { unsigned short len; unsigned char arr[5]; } T_KeyCode;

        /* VARCHAR          T_EmvKey     [256 + 1]; */ 
struct { unsigned short len; unsigned char arr[257]; } T_EmvKey;

        /* EXEC SQL END DECLARE SECTION; */ 



        /* EXEC SQL CONTEXT USE :tab_ParamCtx[nIndexCtx].ctx; */ 

        #ifdef DEBUGIN
        	sprintf(sLine, "Start Get_EMV_Key(%s,%s)", sPan, sKeyCode);
        	trace_event(sLine, PROCESSING);
        #else
        	sprintf(sLine, "Start Get_EMV_Key(%s)", sKeyCode);
        	trace_event(sLine, PROCESSING);        	
        #endif
