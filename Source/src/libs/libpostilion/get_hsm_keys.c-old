/*****************************************************************************/
/* GetCVK                                                                    */
/*------------                                                               */
/*  Fonction : fonction qui recupere les cles CVKA CVKB.                     */
/*  Entree   : Le numero de la carte & index de cles                         */
/*  Sortie   : La cle CVKA.                                              	 */
/*             La cle CVKB.                                              	 */
/*****************************************************************************/

int GetCVK( int nIndiceCtx, char *sPan, char *CVKA ,char *CVKB )
{
    struct sqlca sqlca;
    char sLine [ MAX_LINE_TRC];

    /* EXEC SQL BEGIN DECLARE SECTION; */ 

    	int      response;
    	/* VARCHAR          T_Pan  [22 + 1]; */ 
struct { unsigned short len; unsigned char arr[23]; } T_Pan;

    	/* varchar             T_CVKA [256 + 1]; */ 
struct { unsigned short len; unsigned char arr[257]; } T_CVKA;

    	/* varchar             T_CVKB [256 + 1]; */ 
struct { unsigned short len; unsigned char arr[257]; } T_CVKB;

	/* EXEC SQL END DECLARE SECTION; */ 



	/* EXEC SQL CONTEXT USE :tab_ParamCtx[nIndiceCtx].ctx; */ 


#ifdef DEBUGIN
		sprintf(sLine, "Start GetCVK(%d,%s,%d)", nIndiceCtx ,sPan , strlen ( sPan ));
		trace_event(sLine, PROCESSING);
	#else
		sprintf(sLine, "Start GetCVK()");
		trace_event(sLine, PROCESSING);
	#endif
/* Mehdi ELyajizi PCI */
	memset(T_CVKA.arr,    	0, sizeof(T_CVKA.arr));
        T_CVKA.len = 0;/*YK011003*/
	memset(T_CVKB.arr,    	0, sizeof(T_CVKB.arr));
	T_CVKB.len = 0;/*YK011003*/
	memset(T_Pan.arr , 0, sizeof(T_Pan.arr));
	T_Pan.len = 22;

	memcpy(T_Pan.arr, sPan, strlen(sPan));
	T_Pan.len = strlen(sPan);
 
	response = 909;
	/* EXEC SQL WHENEVER SQLERROR GOTO cvk_key_exception; */ 

	/* EXEC SQL EXECUTE
	BEGIN
    	:response := PCRD_GET_HSM_KEY.GET_CVK_KEY(	:T_Pan   ,
         	                 						:T_CVKA  ,
       		                  						:T_CVKB
           		              					 );
	END;
	END-EXEC; */ 

{
 struct sqlexd sqlstm;
 sqlstm.sqlvsn = 12;
 sqlstm.arrsiz = 4;
 sqlstm.sqladtp = &sqladt;
 sqlstm.sqltdsp = &sqltds;
 sqlstm.stmt = "begin :response := PCRD_GET_HSM_KEY . GET_CVK_KEY ( :T_Pan ,\
 :T_CVKA , :T_CVKB ) ; END ;";
 sqlstm.iters = (unsigned int  )1;
 sqlstm.offset = (unsigned int  )5;
 sqlstm.cud = sqlcud0;
 sqlstm.sqlest = (unsigned char  *)&sqlca;
 sqlstm.sqlety = (unsigned short)4352;
 sqlstm.occurs = (unsigned int  )0;
 sqlstm.sqhstv[0] = (unsigned char  *)&response;
 sqlstm.sqhstl[0] = (unsigned long )sizeof(int);
 sqlstm.sqhsts[0] = (         int  )0;
 sqlstm.sqindv[0] = (         short *)0;
 sqlstm.sqinds[0] = (         int  )0;
 sqlstm.sqharm[0] = (unsigned long )0;
 sqlstm.sqadto[0] = (unsigned short )0;
 sqlstm.sqtdso[0] = (unsigned short )0;
 sqlstm.sqhstv[1] = (unsigned char  *)&T_Pan;
 sqlstm.sqhstl[1] = (unsigned long )25;
 sqlstm.sqhsts[1] = (         int  )0;
 sqlstm.sqindv[1] = (         short *)0;
 sqlstm.sqinds[1] = (         int  )0;
 sqlstm.sqharm[1] = (unsigned long )0;
 sqlstm.sqadto[1] = (unsigned short )0;
 sqlstm.sqtdso[1] = (unsigned short )0;
 sqlstm.sqhstv[2] = (unsigned char  *)&T_CVKA;
 sqlstm.sqhstl[2] = (unsigned long )259;
 sqlstm.sqhsts[2] = (         int  )0;
 sqlstm.sqindv[2] = (         short *)0;
 sqlstm.sqinds[2] = (         int  )0;
 sqlstm.sqharm[2] = (unsigned long )0;
 sqlstm.sqadto[2] = (unsigned short )0;
 sqlstm.sqtdso[2] = (unsigned short )0;
 sqlstm.sqhstv[3] = (unsigned char  *)&T_CVKB;
 sqlstm.sqhstl[3] = (unsigned long )259;
 sqlstm.sqhsts[3] = (         int  )0;
 sqlstm.sqindv[3] = (         short *)0;
 sqlstm.sqinds[3] = (         int  )0;
 sqlstm.sqharm[3] = (unsigned long )0;
 sqlstm.sqadto[3] = (unsigned short )0;
 sqlstm.sqtdso[3] = (unsigned short )0;
 sqlstm.sqphsv = sqlstm.sqhstv;
 sqlstm.sqphsl = sqlstm.sqhstl;
 sqlstm.sqphss = sqlstm.sqhsts;
 sqlstm.sqpind = sqlstm.sqindv;
 sqlstm.sqpins = sqlstm.sqinds;
 sqlstm.sqparm = sqlstm.sqharm;
 sqlstm.sqparc = sqlstm.sqharc;
 sqlstm.sqpadto = sqlstm.sqadto;
 sqlstm.sqptdso = sqlstm.sqtdso;
 sqlcxt(&(tab_ParamCtx[nIndiceCtx].ctx), &sqlctx, &sqlstm, &sqlfpn);
 if (sqlca.sqlcode < 0) goto cvk_key_exception;
}



	if (response == OK)
	{
        memcpy(CVKA, T_CVKA.arr, T_CVKA.len);
        memcpy(CVKB, T_CVKB.arr, T_CVKB.len);
#ifdef DEBUGIN
        	sprintf(sLine, "End   GetCVK(%.32s,%.32s)", CVKA, CVKB);
        	trace_event(sLine, PROCESSING);
        #else
        		sprintf(sLine, "End   GetCVK(OK)");
        		trace_event(sLine, PROCESSING);
      #endif
        return(OK);
	}

	trace_event("End   GetCVK(NOK)", PROCESSING);
	return(NOK);

    cvk_key_exception :
	/* EXEC SQL WHENEVER SQLERROR CONTINUE; */ 

	sprintf(sLine, "%s",sqlca.sqlerrm.sqlerrmc);
	trace_event(sLine, ERROR);
	trace_event("End  GetCVK(MALFUNCTION)", PROCESSING);
    return(HSM_MALFUNCTION);
}


/*****************************************************************************/
/* GetPVK                                                                    */
/*------------                                                               */
/*  Fonction : fonction qui recupere les cles PVKA PVKB.                     */
/*  Entree   : Le numero de la carte & index                                 */
/*  Sortie   : La cle PVKA.                                              	 */
/*             La cle PVKB.                                              	 */
/*****************************************************************************/

int GetPVK( int nIndiceCtx, char *sPan, char pvki, char *PVKA ,char *PVKB )
{
    struct sqlca sqlca;
    char sLine [ MAX_LINE_TRC];

    /* EXEC SQL BEGIN DECLARE SECTION; */ 

    	int      response;
    	/* VARCHAR          T_Pan  [22 + 1]; */ 
struct { unsigned short len; unsigned char arr[23]; } T_Pan;

    	/* varchar             T_PVKA [256 + 1]; */ 
struct { unsigned short len; unsigned char arr[257]; } T_PVKA;

    	/* varchar             T_PVKB [256 + 1]; */ 
struct { unsigned short len; unsigned char arr[257]; } T_PVKB;

        int              T_PVKI;
	/* EXEC SQL END DECLARE SECTION; */ 



	/* EXEC SQL CONTEXT USE :tab_ParamCtx[nIndiceCtx].ctx; */ 

#ifdef DEBUGIN
		sprintf(sLine, "Start GetPVK(%.16s,%c)", sPan,pvki);
		trace_event(sLine, PROCESSING);
        #else
		sprintf(sLine, "Start GetPVK()");
		trace_event(sLine, PROCESSING);
	#endif
	memset( T_PVKA.arr,        	0, sizeof(T_PVKA.arr));
	T_PVKA.len = 0;/*YK011003*/
	memset( T_PVKB.arr,        	0, sizeof(T_PVKB.arr));
	T_PVKB.len = 0;/*YK011003*/
	memset( T_Pan.arr, 		0, sizeof(T_Pan.arr));
	T_Pan.len = 22;
    T_PVKI = 0;

	memcpy( T_Pan.arr, sPan, strlen(sPan) );
	T_Pan.len = strlen(sPan);
  T_PVKI = atoi(&pvki);
#ifdef DEBUGIN
	sprintf(sLine, "PVKI=[%d]", T_PVKI);
	trace_event(sLine, PROCESSING);
      #endif
	response = 909;
	/* EXEC SQL WHENEVER SQLERROR GOTO pvk_key_exception; */ 

	/* EXEC SQL EXECUTE
	BEGIN
    	:response := PCRD_GET_HSM_KEY.GET_PVK_KEY_VERIF (	:T_Pan   ,
         	                 		 		:T_PVKI  ,
         	                 				:T_PVKA  ,
       		                  				:T_PVKB
           		              	 		);
	END;
	END-EXEC; */ 

{
 struct sqlexd sqlstm;
 sqlstm.sqlvsn = 12;
 sqlstm.arrsiz = 5;
 sqlstm.sqladtp = &sqladt;
 sqlstm.sqltdsp = &sqltds;
 sqlstm.stmt = "begin :response := PCRD_GET_HSM_KEY . GET_PVK_KEY_VERIF ( :T\
_Pan , :T_PVKI , :T_PVKA , :T_PVKB ) ; END ;";
 sqlstm.iters = (unsigned int  )1;
 sqlstm.offset = (unsigned int  )36;
 sqlstm.cud = sqlcud0;
 sqlstm.sqlest = (unsigned char  *)&sqlca;
 sqlstm.sqlety = (unsigned short)4352;
 sqlstm.occurs = (unsigned int  )0;
 sqlstm.sqhstv[0] = (unsigned char  *)&response;
 sqlstm.sqhstl[0] = (unsigned long )sizeof(int);
 sqlstm.sqhsts[0] = (         int  )0;
 sqlstm.sqindv[0] = (         short *)0;
 sqlstm.sqinds[0] = (         int  )0;
 sqlstm.sqharm[0] = (unsigned long )0;
 sqlstm.sqadto[0] = (unsigned short )0;
 sqlstm.sqtdso[0] = (unsigned short )0;
 sqlstm.sqhstv[1] = (unsigned char  *)&T_Pan;
 sqlstm.sqhstl[1] = (unsigned long )25;
 sqlstm.sqhsts[1] = (         int  )0;
 sqlstm.sqindv[1] = (         short *)0;
 sqlstm.sqinds[1] = (         int  )0;
 sqlstm.sqharm[1] = (unsigned long )0;
 sqlstm.sqadto[1] = (unsigned short )0;
 sqlstm.sqtdso[1] = (unsigned short )0;
 sqlstm.sqhstv[2] = (unsigned char  *)&T_PVKI;
 sqlstm.sqhstl[2] = (unsigned long )sizeof(int);
 sqlstm.sqhsts[2] = (         int  )0;
 sqlstm.sqindv[2] = (         short *)0;
 sqlstm.sqinds[2] = (         int  )0;
 sqlstm.sqharm[2] = (unsigned long )0;
 sqlstm.sqadto[2] = (unsigned short )0;
 sqlstm.sqtdso[2] = (unsigned short )0;
 sqlstm.sqhstv[3] = (unsigned char  *)&T_PVKA;
 sqlstm.sqhstl[3] = (unsigned long )259;
 sqlstm.sqhsts[3] = (         int  )0;
 sqlstm.sqindv[3] = (         short *)0;
 sqlstm.sqinds[3] = (         int  )0;
 sqlstm.sqharm[3] = (unsigned long )0;
 sqlstm.sqadto[3] = (unsigned short )0;
 sqlstm.sqtdso[3] = (unsigned short )0;
 sqlstm.sqhstv[4] = (unsigned char  *)&T_PVKB;
 sqlstm.sqhstl[4] = (unsigned long )259;
 sqlstm.sqhsts[4] = (         int  )0;
 sqlstm.sqindv[4] = (         short *)0;
 sqlstm.sqinds[4] = (         int  )0;
 sqlstm.sqharm[4] = (unsigned long )0;
 sqlstm.sqadto[4] = (unsigned short )0;
 sqlstm.sqtdso[4] = (unsigned short )0;
 sqlstm.sqphsv = sqlstm.sqhstv;
 sqlstm.sqphsl = sqlstm.sqhstl;
 sqlstm.sqphss = sqlstm.sqhsts;
 sqlstm.sqpind = sqlstm.sqindv;
 sqlstm.sqpins = sqlstm.sqinds;
 sqlstm.sqparm = sqlstm.sqharm;
 sqlstm.sqparc = sqlstm.sqharc;
 sqlstm.sqpadto = sqlstm.sqadto;
 sqlstm.sqptdso = sqlstm.sqtdso;
 sqlcxt(&(tab_ParamCtx[nIndiceCtx].ctx), &sqlctx, &sqlstm, &sqlfpn);
 if (sqlca.sqlcode < 0) goto pvk_key_exception;
}



	if (response == OK)
	{
        memcpy(PVKA, T_PVKA.arr, T_PVKA.len );
        memcpy(PVKB, T_PVKB.arr, T_PVKB.len );
#ifdef DEBUGIN
        	sprintf(sLine, "End   GetPVK(%.16s,%.16s)", PVKA, PVKB);
        	trace_event(sLine, PROCESSING);	
     #else
					sprintf(sLine, "End   GetPVK(OK)");
					trace_event(sLine, PROCESSING);
	  #endif

        return(OK);
	}

	trace_event("End   GetPVK(NOK)", PROCESSING);
	return(NOK);

    pvk_key_exception :
    /* EXEC SQL WHENEVER SQLERROR CONTINUE; */ 

    sprintf(sLine, "%s",sqlca.sqlerrm.sqlerrmc);
    trace_event(sLine, ERROR);                                                                                                     
    trace_event("End  GetPVK(MALFUNCTION)", PROCESSING);                                                                           
    return(HSM_MALFUNCTION);         

}



/*****************************************************************************/
/* GetZMK                                                        	         */
/*----------------                                                           */
/*  Fonction : fonction qui recupere la cle ZMK.                             */
/*  Entree   : L'identificateur du resource.                                */
/*  Sortie   : La cle ZMK.                                      	         */
/*****************************************************************************/

int     GetZMK ( int nIndiceCtx , char *resource_id, char *ZmK)
{
    struct sqlca sqlca;
    char sLine [ MAX_LINE_TRC];

	/* EXEC SQL BEGIN DECLARE SECTION; */ 

		int		 response;
        char     T_resource_id		[ 6 + 1 ];
        /* VARCHAR     T_ZmK    			[256 + 1 ]; */ 
struct { unsigned short len; unsigned char arr[257]; } T_ZmK;
 /* TDES  04/24/03 */
	/* EXEC SQL END DECLARE SECTION; */ 



	/* EXEC SQL CONTEXT USE :tab_ParamCtx[nIndiceCtx].ctx; */ 

	sprintf(sLine, "Start GetZMK (%.6s)", resource_id);
	trace_event(sLine, PROCESSING);

	memset(T_ZmK.arr    ,       0, sizeof(T_ZmK.arr));
  T_ZmK.len = 0;
  
	memset(T_resource_id,  0, sizeof(T_resource_id));

	memcpy(T_resource_id, resource_id, 6); 

	sprintf(sLine, "GET_ZMK_KEY (%.6s)", T_resource_id);
	trace_event(sLine, PROCESSING);
	
	response = 909;
	/* EXEC SQL WHENEVER SQLERROR GOTO zmk_key_exception; */ 

	/* EXEC SQL EXECUTE
	BEGIN
		:response := PCRD_GET_HSM_KEY.GET_ZMK_KEY(:T_resource_id,
						 	:T_ZmK
							);
	END;
	END-EXEC; */ 

{
 struct sqlexd sqlstm;
 sqlstm.sqlvsn = 12;
 sqlstm.arrsiz = 5;
 sqlstm.sqladtp = &sqladt;
 sqlstm.sqltdsp = &sqltds;
 sqlstm.stmt = "begin :response := PCRD_GET_HSM_KEY . GET_ZMK_KEY ( :T_resou\
rce_id , :T_ZmK ) ; END ;";
 sqlstm.iters = (unsigned int  )1;
