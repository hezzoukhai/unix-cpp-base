Iss_Bank_Code , :T_Iss_App_Data , :T_Icc_App_Index , :T_Cvr ) ; END ;";
    sqlstm.iters = (unsigned int  )1;
    sqlstm.offset = (unsigned int  )528;
    sqlstm.cud = sqlcud0;
