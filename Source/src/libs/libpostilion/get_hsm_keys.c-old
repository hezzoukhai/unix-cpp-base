int GET_EMV_KEYS( int nIndiceCtx, char *p_card_number,            
                                 char *p_issuing_bank_code,
                                 char *p_issuing_bin,
                                 char *p_product_code,
                                 char *p_icc_application_index,
                                 char *p_key_code,
                                 char *sEMV_key)
{
    struct sqlca sqlca;
    char sLine [ MAX_LINE_TRC];
   char *CardTrunc[22 +1];
   
   memset(CardTrunc, 0, sizeof(CardTrunc));

        /* EXEC SQL BEGIN DECLARE SECTION; */ 

        int              response;
        /* VARCHAR          T_Pan    [ 22 + 1]; */ 
struct { unsigned short len; unsigned char arr[23]; } T_Pan;

        /* VARCHAR          T_EMV_Key [256 + 1]; */ 
struct { unsigned short len; unsigned char arr[257]; } T_EMV_Key;

        /* VARCHAR          T_ISSUING_BANK_CODE[6 + 1]; */ 
struct { unsigned short len; unsigned char arr[7]; } T_ISSUING_BANK_CODE;

        /* VARCHAR          T_ISSUING_BIN[11 + 1]; */ 
struct { unsigned short len; unsigned char arr[12]; } T_ISSUING_BIN;

