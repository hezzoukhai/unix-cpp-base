/*****************************************************************************/
/* GetResourceTMK                                                            */
/*----------------                                                           */
/*  Fonction : fonction qui recupere la cle TMK.                             */
/*  Entree   : L'identificateur du resource.                                */
/*  Sortie   : La cle TMK.                                                   */
/*****************************************************************************/

int     GetResourceTMK ( int nIndiceCtx , char *resource_id, char *TmK)
{
    struct sqlca sqlca;
    char sLine [ MAX_LINE_TRC];

    /* EXEC SQL BEGIN DECLARE SECTION; */ 

        int      response;
        char     T_resource_id      [ 6 + 1 ];
        /* VARCHAR  T_TmK              [256 + 1 ]; */ 
struct { unsigned short len; unsigned char arr[257]; } T_TmK;

    /* EXEC SQL END DECLARE SECTION; */ 



    /* EXEC SQL CONTEXT USE :tab_ParamCtx[nIndiceCtx].ctx; */ 


    memset(T_TmK.arr    ,       0, sizeof(T_TmK.arr));
    T_TmK.len = 0;

        memset(T_resource_id,  0, sizeof(T_resource_id));
    memcpy(T_resource_id, resource_id, 6);

    sprintf(sLine, "Start GetResourceTMK (%.6s)", T_resource_id);
    trace_event(sLine, PROCESSING);

    response = 909;
    /* EXEC SQL WHENEVER SQLERROR GOTO tmk_key_exception; */ 

    /* EXEC SQL EXECUTE
    BEGIN
        :response := PCRD_GET_HSM_KEY.GET_RES_TMK_KEY(  :T_resource_id,
                                                                                :T_TmK);
    END;
    END-EXEC; */ 

{
    struct sqlexd sqlstm;
    sqlstm.sqlvsn = 12;
    sqlstm.arrsiz = 8;
    sqlstm.sqladtp = &sqladt;
    sqlstm.sqltdsp = &sqltds;
    sqlstm.stmt = "begin :response := PCRD_GET_HSM_KEY . GET_RES_TMK_KEY ( :\
T_resource_id , :T_TmK ) ; END ;";
    sqlstm.iters = (unsigned int  )1;
    sqlstm.offset = (unsigned int  )501;
    sqlstm.cud = sqlcud0;
    sqlstm.sqlest = (unsigned char  *)&sqlca;
    sqlstm.sqlety = (unsigned short)4352;
    sqlstm.occurs = (unsigned int  )0;
    sqlstm.sqhstv[0] = (unsigned char  *)&response;
    sqlstm.sqhstl[0] = (unsigned long )sizeof(int);
    sqlstm.sqhsts[0] = (         int  )0;
    sqlstm.sqindv[0] = (         short *)0;
    sqlstm.sqinds[0] = (         int  )0;
    sqlstm.sqharm[0] = (unsigned long )0;
    sqlstm.sqadto[0] = (unsigned short )0;
    sqlstm.sqtdso[0] = (unsigned short )0;
    sqlstm.sqhstv[1] = (unsigned char  *)T_resource_id;
    sqlstm.sqhstl[1] = (unsigned long )7;
    sqlstm.sqhsts[1] = (         int  )0;
    sqlstm.sqindv[1] = (         short *)0;
    sqlstm.sqinds[1] = (         int  )0;
    sqlstm.sqharm[1] = (unsigned long )0;
    sqlstm.sqadto[1] = (unsigned short )0;
    sqlstm.sqtdso[1] = (unsigned short )0;
    sqlstm.sqhstv[2] = (unsigned char  *)&T_TmK;
    sqlstm.sqhstl[2] = (unsigned long )259;
    sqlstm.sqhsts[2] = (         int  )0;
    sqlstm.sqindv[2] = (         short *)0;
    sqlstm.sqinds[2] = (         int  )0;
    sqlstm.sqharm[2] = (unsigned long )0;
    sqlstm.sqadto[2] = (unsigned short )0;
    sqlstm.sqtdso[2] = (unsigned short )0;
    sqlstm.sqphsv = sqlstm.sqhstv;
    sqlstm.sqphsl = sqlstm.sqhstl;
    sqlstm.sqphss = sqlstm.sqhsts;
    sqlstm.sqpind = sqlstm.sqindv;
    sqlstm.sqpins = sqlstm.sqinds;
    sqlstm.sqparm = sqlstm.sqharm;
    sqlstm.sqparc = sqlstm.sqharc;
    sqlstm.sqpadto = sqlstm.sqadto;
    sqlstm.sqptdso = sqlstm.sqtdso;
    sqlcxt(&(tab_ParamCtx[nIndiceCtx].ctx), &sqlctx, &sqlstm, &sqlfpn);
    if (sqlca.sqlcode < 0) goto tmk_key_exception;
}



    sprintf(sLine, "response :  (%d)", response);
    trace_event(sLine, PROCESSING);

    if (response == OK)
    {
        memcpy(TmK, T_TmK.arr, T_TmK.len );
        #ifdef DEBUGIN
        	sprintf(sLine, "End   GetResourceTMK (%.256s)", TmK);
        	trace_event(sLine, PROCESSING);
        #else
         	sprintf(sLine, "End   GetResourceTMK (OK)");
        	trace_event(sLine, PROCESSING);       	
        #endif
        return(OK);
    }

    trace_event("End   GetResourceTMK (NOK)", PROCESSING);
    return(NOK);

    tmk_key_exception :
    /* EXEC SQL WHENEVER SQLERROR CONTINUE; */ 

    sprintf(sLine, "%s",sqlca.sqlerrm.sqlerrmc);
    trace_event(sLine, ERROR);
    trace_event("End  GetResourceTMK(MALFUNCTION)", PROCESSING);
    return(HSM_MALFUNCTION);

}

/*****************************************************************************/
/* GetCVRFromIAD                                                             */
/*----------------                                                           */
/*  Fonction : fonction qui recupere le CVR de l'Issuer Application Data IAD */
/*  Author   : M.EL KABLI   Date: 25/04/2006				     */
/*  Entree   : Issuer Application Data, Bank Code, Acc Application Code      */
/*  Sortie   : CVR 							     */
/*****************************************************************************/

int     GetCVRFromIAD ( int nIndiceCtx , char *Iss_App_Data, char *Iss_Bank_Code, char *Icc_App_Index, char *Cvr)
{
    struct sqlca sqlca;
    char sLine [ MAX_LINE_TRC];

    /* EXEC SQL BEGIN DECLARE SECTION; */ 

        int      response;
        char     T_Iss_App_Data     [36 + 1 ]; /**Linux MKB110907**/
        char     T_Icc_App_Index    [4  + 1 ];
        char     T_Iss_Bank_Code    [6  + 1 ];
        /* VARCHAR  T_Cvr              [32  + 1 ]; */ 
struct { unsigned short len; unsigned char arr[33]; } T_Cvr;
 /**Linux MKB110907**/
    /* EXEC SQL END DECLARE SECTION; */ 



    sprintf(sLine, "Start GetCVRFromIAD:IAD(%s),len(%d),Iss(%s),Icc(%s)", 
		   Iss_App_Data,strlen(Iss_App_Data),Iss_Bank_Code,Icc_App_Index);
    trace_event(sLine, PROCESSING);

    /* EXEC SQL CONTEXT USE :tab_ParamCtx[nIndiceCtx].ctx; */ 


    memset(T_Cvr.arr    ,       0, sizeof(T_Cvr.arr));
    T_Cvr.len = 0;
    
    memset(T_Iss_App_Data,  0, sizeof(T_Iss_App_Data));
    memcpy(T_Iss_App_Data, Iss_App_Data, strlen(Iss_App_Data));

    memset(T_Icc_App_Index,  0, sizeof(T_Icc_App_Index));
    memcpy(T_Icc_App_Index, Icc_App_Index, strlen(Icc_App_Index));

    memset(T_Iss_Bank_Code,  0, sizeof(T_Iss_Bank_Code));
    memcpy(T_Iss_Bank_Code, Iss_Bank_Code, strlen(Iss_Bank_Code));

    response = 909;

    /* EXEC SQL WHENEVER SQLERROR GOTO cvr_iad_exception; */ 

    /* EXEC SQL EXECUTE
    BEGIN
        :response := PCRD_EMV_TOOLS.GET_EMV_IAD_CVR(    :T_Iss_Bank_Code,
							:T_Iss_App_Data, 
							:T_Icc_App_Index,
							:T_Cvr);
    END;
    END-EXEC; */ 

{
    struct sqlexd sqlstm;
    sqlstm.sqlvsn = 12;
    sqlstm.arrsiz = 8;
    sqlstm.sqladtp = &sqladt;
    sqlstm.sqltdsp = &sqltds;
