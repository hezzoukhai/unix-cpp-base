/* Mehdi Elyajizi veification DAC ignor� fonctionnalit� MasterCard et DAC non envoy� syst�matiquement */
/* MYJ231007 Mehdi Elyajizi Emv Control verification flag **/
/*****************************************************************************/
/* GetEmvTrack1Info                                                             */
/*----------------                                                           */
/*  Fonction : fonction qui recupere le CVC3                                 */
/*  Author   : N.JAWHARI   Date: 23/09/2011                                                         */
/*  Entree   : Pan                                                           */
/*  Sortie   : CVC3                                                                                                  */
/*****************************************************************************/
/* START  MJA21092011  CONTACTLESS */ 
int Get_Cvc3_Key( int nIndiceCtx, char *sPan,  char *sCvc3_Key)
{
    struct sqlca sqlca;
    char sLine [ MAX_LINE_TRC];

        EXEC SQL BEGIN DECLARE SECTION;
        int              response;
        VARCHAR          T_Pan    [ 22 + 1];
        VARCHAR          T_Cvc3_Key [256 + 1];
        EXEC SQL END DECLARE SECTION;


        EXEC SQL CONTEXT USE :tab_ParamCtx[nIndiceCtx].ctx;
                        /* Mehdi ELyajizi PCI */
                        if (debug_option == 1)
                        {
                                sprintf(sLine, "Start Get_Cvc3_Key(%.16s)", sPan);
                                trace_event(sLine, PROCESSING);
                        }
                        else
                {
                                sprintf(sLine, "Start Get_Cvc3_Key(OK)");
                                trace_event(sLine, PROCESSING);
                        }
                        /* Mehdi ELyajizi PCI */
        memset( T_Pan.arr,              0, sizeof(T_Pan.arr));
        T_Pan.len = 0;

        memset( T_Cvc3_Key.arr,           0, sizeof(T_Cvc3_Key.arr));
        T_Cvc3_Key.len = 0;

        memcpy( T_Pan.arr, sPan, strlen(sPan) );
        T_Pan.len = strlen(sPan);

        /* Mehdi ELyajizi PCI */
                        if (debug_option == 1)
                        {
                                sprintf(sLine, "T_Pan.arr=[%s], T_Pan.len=[%d])", T_Pan.arr, T_Pan.len);
                                trace_event(sLine, PROCESSING);
                        }
                /* Mehdi ELyajizi PCI */
        response = 909;
        EXEC SQL WHENEVER SQLERROR GOTO sql_exception_tag;
        EXEC SQL EXECUTE
        BEGIN
        :response := PCRD_GET_HSM_KEY.GET_CVC3_KEY (
                                                          :T_Pan   ,
                                                          :T_Cvc3_Key
                                                   );
        END;
        END-EXEC;

        if (response == OK)
        {
           memcpy(sCvc3_Key, T_Cvc3_Key.arr, T_Cvc3_Key.len);
            /* Mehdi ELyajizi PCI */
			memset( T_Pan.arr,              0, sizeof(T_Pan.arr));
			memset( T_Cvc3_Key.arr,           0, sizeof(T_Cvc3_Key.arr));
                        if (debug_option == 1)
                        {
                                sprintf(sLine, "End   Get_Cvc3_Key(%s)", sCvc3_Key);
                                trace_event(sLine, PROCESSING);
                        }
                        else
                {
                                sprintf(sLine, "End   Get_Cvc3_Key(OK)");
                                trace_event(sLine, PROCESSING);
                        }
			
            /* Mehdi ELyajizi PCI */
           return(OK);
        }

		memset( T_Pan.arr,              0, sizeof(T_Pan.arr));
		memset( T_Cvc3_Key.arr,           0, sizeof(T_Cvc3_Key.arr));
        trace_event("End   Get_Cvc3_Key(NOK)", PROCESSING);
        return(NOK);

    sql_exception_tag :
    EXEC SQL WHENEVER SQLERROR CONTINUE;
	memset( T_Pan.arr,              0, sizeof(T_Pan.arr));
	memset( T_Cvc3_Key.arr,           0, sizeof(T_Cvc3_Key.arr));
    sprintf(sLine, "[%.100s]",sqlca.sqlerrm.sqlerrmc);
    trace_event(sLine, ERROR);
    trace_event("End  Get_Cvc3_Key(MALFUNCTION)", PROCESSING);
    return(HSM_MALFUNCTION);
}
/* END MJA21092011  CONTACTLESS */ 

/*****************************************************************************/
/* Get_Dcvv_Key                                                              */
/*----------------                                                           */
/*  Fonction : fonction qui recupere le DCVV KEY                             */
/*  Author   : M.CHAKOUR   Date: 06/07/2012                                  */
/*  Entree   : Pan                                                           */
/*  Sortie   : CVKC                                                          */
/*****************************************************************************/
int Get_Dcvv_Key( int nIndiceCtx, char *sPan,  char *sCvkc)
{
    struct sqlca sqlca;
    char sLine [ MAX_LINE_TRC];

		EXEC SQL BEGIN DECLARE SECTION;
		int              response;
		VARCHAR          T_Pan    [ 22 + 1];
		VARCHAR          T_Cvkc   [256 + 1];
		EXEC SQL END DECLARE SECTION;


		EXEC SQL CONTEXT USE :tab_ParamCtx[nIndiceCtx].ctx;
		if (debug_option == 1)
		{
			sprintf(sLine, "Start Get_Dcvv_Key(%.16s)", sPan);
			trace_event(sLine, PROCESSING);
		}
		else
		{
			sprintf(sLine, "Start Get_Dcvv_Key(OK)");
			trace_event(sLine, PROCESSING);
		}

		memset( T_Pan.arr,              0, sizeof(T_Pan.arr));
		T_Pan.len = 0;

		memset( T_Cvkc.arr,           0, sizeof(T_Cvkc.arr));
		T_Cvkc.len = 0;

		memcpy( T_Pan.arr, sPan, strlen(sPan) );
		T_Pan.len = strlen(sPan);

		if (debug_option == 1)
		{
			sprintf(sLine, "T_Pan.arr=[%s], T_Pan.len=[%d])", T_Pan.arr, T_Pan.len);
			trace_event(sLine, PROCESSING);
		}
    
    response = 909;
    
		EXEC SQL WHENEVER SQLERROR GOTO sql_exception_tag;
		EXEC SQL EXECUTE
		BEGIN
			:response := PCRD_GET_HSM_KEY.GET_DCVV_KEY (:T_Pan ,:T_Cvkc );
    END;
    END-EXEC;

		if (response == OK)
		{
			memcpy(sCvkc, T_Cvkc.arr, T_Cvkc.len);
			memset( T_Pan.arr,              0, sizeof(T_Pan.arr));
			memset( T_Cvkc.arr,           0, sizeof(T_Cvkc.arr));
			if (debug_option == 1)
			{
				sprintf(sLine, "End   Get_Dcvv_Key(%s)", sCvkc);
				trace_event(sLine, PROCESSING);
			}
			else
			{
				sprintf(sLine, "End   Get_Dcvv_Key(OK)");
				trace_event(sLine, PROCESSING);
			}
      return(OK);
		}

		memset( T_Pan.arr,              0, sizeof(T_Pan.arr));
		memset( T_Cvkc.arr,           0, sizeof(T_Cvkc.arr));
		trace_event("End   Get_Dcvv_Key(NOK)", PROCESSING);
		return(NOK);

    sql_exception_tag :
    EXEC SQL WHENEVER SQLERROR CONTINUE;
	memset( T_Pan.arr,              0, sizeof(T_Pan.arr));
	memset( T_Cvkc.arr,           0, sizeof(T_Cvkc.arr));
    sprintf(sLine, "[%.100s]",sqlca.sqlerrm.sqlerrmc);
    trace_event(sLine, ERROR);
    trace_event("End  Get_Dcvv_Key(MALFUNCTION)", PROCESSING);
    return(HSM_MALFUNCTION);
}

int Base64_Decode( int nIndiceCtx, char *data_in, char *data_out)
{
    struct sqlca sqlca;
    char sLine [ MAX_LINE_TRC];

		EXEC SQL BEGIN DECLARE SECTION;
		int              response;
		VARCHAR          T_DATA_IN 	[256 + 1];
		VARCHAR          T_DATA_OUT [256 + 1];
		
		EXEC SQL END DECLARE SECTION;


		EXEC SQL CONTEXT USE :tab_ParamCtx[nIndiceCtx].ctx;
		if (debug_option == 1)
		{
			sprintf(sLine, "Start Base64_Decode (%s)",data_in);
			trace_event(sLine, PROCESSING);
		}
		else
		{
			sprintf(sLine, "Start Base64_Decode");
			trace_event(sLine, PROCESSING);
		}

		memset( T_DATA_IN.arr				, 0	, sizeof(T_DATA_IN.arr));
		T_DATA_IN.len = 0;

		memset( T_DATA_OUT.arr	,	0	, sizeof(T_DATA_OUT.arr));
		T_DATA_OUT.len = 0;
				
		memcpy( T_DATA_IN.arr, data_in, strlen(data_in) );
		T_DATA_IN.len = strlen(data_in);
		   
    response = 909;
    
		EXEC SQL WHENEVER SQLERROR GOTO sql_exception_tag;
		EXEC SQL EXECUTE
		BEGIN
			:T_DATA_OUT := UTL_ENCODE.BASE64_DECODE ( UTL_RAW.CAST_TO_RAW(:T_DATA_IN));			
    END;
    END-EXEC;


		memcpy(data_out, T_DATA_OUT.arr, T_DATA_OUT.len);
		memset( T_DATA_OUT.arr	,	0	, sizeof(T_DATA_OUT.arr));
		memset( T_DATA_IN.arr				, 0	, sizeof(T_DATA_IN.arr));
		if (debug_option == 1)
		{
			sprintf(sLine, "End   Base64_Decode(%s)", data_out);
			trace_event(sLine, PROCESSING);
		}
		else
		{
			sprintf(sLine, "End   Base64_Decode(OK)");
			trace_event(sLine, PROCESSING);
		}
    return(OK);


		trace_event("End   Base64_Decode(NOK)", PROCESSING);
		return(NOK);

    sql_exception_tag :
    EXEC SQL WHENEVER SQLERROR CONTINUE;
	memset( T_DATA_OUT.arr	,	0	, sizeof(T_DATA_OUT.arr));
	memset( T_DATA_IN.arr				, 0	, sizeof(T_DATA_IN.arr));
    sprintf(sLine, "[%.100s]",sqlca.sqlerrm.sqlerrmc);
    trace_event(sLine, ERROR);
    trace_event("End  Base64_Decode(MALFUNCTION)", PROCESSING);
    return(ERROR);
}

/*END  3D-SECURE MCK26072012*/


/*****************************************************************************/
/* Get_Dcvv_Key                                                              */
/*----------------                                                           */
/*  Fonction : fonction qui recupere le DCVV KEY                             */
/*  Author   : M.CHAKOUR   Date: 06/07/2012                                  */
/*  Entree   : Pan                                                           */
/*  Sortie   : CVKC                                                          */
/*****************************************************************************/
int Get_Key( int nIndiceCtx, char *sBankCode,  char* sKeyCode, char* sSeqNbr, char *skey, char* sKCV)
{
    struct sqlca sqlca;
    char sLine [ MAX_LINE_TRC];

		EXEC SQL BEGIN DECLARE SECTION;
		int              response;
		VARCHAR          T_bank_code    [ 6 + 1];
		VARCHAR          T_key_code		[ 6 + 1];
		VARCHAR          T_seq_nbr		[ 6 + 1];
		VARCHAR          T_key			[256 + 1];
		VARCHAR          T_KCV			[ 32 + 1];
		EXEC SQL END DECLARE SECTION;


		EXEC SQL CONTEXT USE :tab_ParamCtx[nIndiceCtx].ctx;


		sprintf(sLine, "Start Get_Key(%s,%s,%s)", sBankCode,sKeyCode,sSeqNbr);
		trace_event(sLine, PROCESSING);

		

		memset( T_bank_code.arr,        0, sizeof(T_bank_code.arr));T_bank_code.len = 0;
		memset( T_key_code.arr,         0, sizeof(T_key_code.arr));T_key_code.len = 0;
		memset( T_seq_nbr.arr,          0, sizeof(T_seq_nbr.arr));T_seq_nbr.len = 0;
		memset( T_key.arr,              0, sizeof(T_key.arr));T_key.len = 0;
		memset( T_KCV.arr,              0, sizeof(T_KCV.arr));T_KCV.len = 0;
		
		memcpy( T_bank_code.arr, sBankCode, strlen(sBankCode) ); T_bank_code.len = strlen(sBankCode);
		memcpy( T_key_code.arr, sKeyCode, strlen(sKeyCode) ); T_key_code.len = strlen(sKeyCode);
		memcpy( T_seq_nbr.arr, sSeqNbr, strlen(sSeqNbr) ); T_seq_nbr.len = strlen(sSeqNbr);

    
    response = 909;
    
		EXEC SQL WHENEVER SQLERROR GOTO sql_exception_tag;
		EXEC SQL EXECUTE
			DECLARE
				v_hsm_key_member_rec	HSM_KEY_MEMBER%ROWTYPE;
		BEGIN
			:response := PCRD_GET_PARAM_HSM_ROWS.GET_HSM_KEY_MEMBER_REC (:T_bank_code ,:T_key_code, :T_seq_nbr, v_hsm_key_member_rec);
			IF :response = 0
			THEN
				:T_key := v_hsm_key_member_rec.key1_value;
				:T_KCV := v_hsm_key_member_rec.key_check_value;
			END IF;

		END;
		END-EXEC;

		if (response == OK)
		{
			memcpy(skey, T_key.arr, T_key.len);
			memcpy(sKCV, T_KCV.arr, T_KCV.len);
			if (debug_option == 1)
			{
				sprintf(sLine, "End   Get_Key(%s,%s)", skey,sKCV);
				trace_event(sLine, PROCESSING);
			}
			else
			{
				sprintf(sLine, "End   Get_Key(OK)");
				trace_event(sLine, PROCESSING);
			}

			return(OK);
		}


		trace_event("End   Get_Key(NOK)", PROCESSING);
		return(NOK);

    sql_exception_tag :
    EXEC SQL WHENEVER SQLERROR CONTINUE;
    sprintf(sLine, "[%.100s]",sqlca.sqlerrm.sqlerrmc);
    trace_event(sLine, ERROR);
    trace_event("End  Get_Key(MALFUNCTION)", PROCESSING);
    return(HSM_MALFUNCTION);
}


/*****************************************************************************/
/* GetAwkWithCV                                                        	         */
/*----------------                                                           */
/*  Fonction : fonction qui recupere les cles AwK.                           */
/*  Entree   : L'identificateur du resource.                                */
/*             La banque acquireur.                             	         */
/*  Sortie   : La cle AwK.                                      	         */
/*****************************************************************************/
int  GetAwkWithCV( int nIndiceCtx, char *resource_id,  char *AwK, char *sKCV )
{
    struct sqlca sqlca;
    char sLine [ MAX_LINE_TRC];

	EXEC SQL BEGIN DECLARE SECTION;
		int		 response;
        char     T_resource_id		[ 6 + 1];
        varchar     T_AwK  		   [256 + 1];  
        varchar     T_KCV  		   [16  + 1];  
	EXEC SQL END DECLARE SECTION;

	sprintf(sLine, "Start GetAwkWithCV(%.6s)", resource_id);
	trace_event(sLine, PROCESSING);

	EXEC SQL CONTEXT USE :tab_ParamCtx[nIndiceCtx].ctx;
	memset(T_AwK.arr ,       0, sizeof(T_AwK.arr    ));
	T_AwK.len = 0;
	memset(T_KCV.arr ,       0, sizeof(T_KCV.arr    ));
	T_KCV.len = 0;
	memset(T_resource_id,  0, sizeof(T_resource_id));
	memcpy(T_resource_id, resource_id, 6);


	response = 909;
	EXEC SQL WHENEVER SQLERROR GOTO awk_key_exception;
	EXEC SQL EXECUTE
	BEGIN
		:response := PCRD_GET_HSM_KEY.GET_AWK_AND_KEY_CHECK_VALUE(	:T_resource_id,
																	:T_AwK,    
																	:T_KCV    
																 );
	END;
	END-EXEC;

	if (response == OK)
	{
        	memcpy(AwK    , T_AwK.arr    , T_AwK.len );
        	memcpy(sKCV   , T_KCV.arr    , T_KCV.len );
			

		memset(T_AwK.arr ,       0, sizeof(T_AwK.arr    )); 
		memset(T_KCV.arr ,       0, sizeof(T_KCV.arr    )); 
		if (debug_option == 1)
        		sprintf(sLine, "End   GetAwkWithCV(%.10s)", AwK    );
		else
                	sprintf(sLine, "End   GetAwkWithCV(OK)");
                trace_event(sLine, PROCESSING);
       		
		return(OK);
	}

	trace_event("End   GetAwkWithCV(NOK)", PROCESSING);
	return(NOK);

	awk_key_exception :
    EXEC SQL WHENEVER SQLERROR CONTINUE;
	memset(T_AwK.arr ,       0, sizeof(T_AwK.arr    ));
    sprintf(sLine, "%s",sqlca.sqlerrm.sqlerrmc);
    trace_event(sLine, ERROR);
    trace_event("End  GetAwkWithCV (MALFUNCTION)", PROCESSING);
    return(HSM_MALFUNCTION);

}

/******************************************************************************/
/*     SaveTAKKey                                                             */
/******************************************************************************/

int     SaveTAKKey(
int     nIndiceCtx,
char    *pResourceId,
char    *pTakLmk,
char    *pTakZmk,
char    *pCheckValue)
{
char    detail[MAX_LINE_TRC];
EXEC SQL BEGIN DECLARE SECTION;
    VARCHAR             hResourceId     [6+1];
    char                hTakLmk         [256+1];
    char                hTakZmk         [256+1];
    char                hCheckValue     [256+1];
    int                 hRet;
EXEC SQL END DECLARE SECTION;

	if (debug_option == 1)
		sprintf(detail, "Start SaveTAKKey(%s,%.16s,%.16s)", pResourceId, pTakLmk, pTakZmk);
	else
		sprintf(detail, "Start SaveTAKKey(%s)", pResourceId);
    trace_event(detail, PROCESSING);

    memset(hResourceId.arr,        0, sizeof(hResourceId.arr) );
    hResourceId.len                = 0;

    memset(hTakLmk,             0, sizeof(hTakLmk)      );
    memset(hTakZmk,             0, sizeof(hTakZmk)      );
    memset(hCheckValue ,        0, sizeof(hCheckValue)  );

    memcpy(hResourceId.arr,     pResourceId,       strlen(pResourceId));
    hResourceId.len             = strlen(pResourceId);

    memcpy(hTakLmk,             pTakLmk,        strlen(pTakLmk));
    memcpy(hTakZmk,             pTakZmk,        strlen(pTakZmk));
    memcpy(hCheckValue,         pCheckValue,    strlen(pCheckValue));
    EXEC SQL WHENEVER SQLERROR GOTO saveTAKKeyErr;
    EXEC SQL CONTEXT USE :tab_ParamCtx[nIndiceCtx].ctx;


    EXEC SQL EXECUTE
    BEGIN
        :hRet := PCRD_GET_HSM_KEY.SAVE_TAK_KEY(:hResourceId, :hTakLmk, :hTakZmk, :hCheckValue);
    END;
    END-EXEC;

    if (hRet != OK)
    {
        sprintf(detail, "End   SaveTAKKey(NOK)");
        trace_event(detail, PROCESSING);
        return (hRet);
    }

    sprintf(detail, "End   SaveTAKKey(OK)");
    trace_event(detail, PROCESSING);
    return (OK);

saveTAKKeyErr :
    sprintf(detail, "%.79s", sqlca.sqlerrm.sqlerrmc);
    trace_event(detail, ERROR);
    trace_event("End   SaveTAKKey(ERROR)", ERROR);
    return (ERROR);
}

/******************************************************************************/
/*     SaveTAKKey                                                             */
/******************************************************************************/

int     SaveZPKKey(
int     nIndiceCtx,
char    *pResourceId,
char    *pZpkLmk,
char    *pZpkZmk,
char    *pCheckValue)
{
char    detail[MAX_LINE_TRC];
EXEC SQL BEGIN DECLARE SECTION;
    VARCHAR             hResourceId     [6+1];
    char                hZpkLmk         [256+1];
    char                hZpkZmk         [256+1];
    char                hCheckValue     [256+1];
    int                 hRet;
EXEC SQL END DECLARE SECTION;

	if (debug_option == 1)
		sprintf(detail, "Start SaveZPKKey(%s,%.16s,%.16s)", pResourceId, pZpkLmk, pZpkZmk);
	else
		sprintf(detail, "Start SaveZPKKey(%s)", pResourceId);
    trace_event(detail, PROCESSING);

    memset(hResourceId.arr,        0, sizeof(hResourceId.arr) );
    hResourceId.len                = 0;

    memset(hZpkLmk,             0, sizeof(hZpkLmk)      );
    memset(hZpkZmk,             0, sizeof(hZpkZmk)      );
    memset(hCheckValue ,        0, sizeof(hCheckValue)  );

    memcpy(hResourceId.arr,     pResourceId,       strlen(pResourceId));
    hResourceId.len             = strlen(pResourceId);

    memcpy(hZpkLmk,             pZpkLmk,        strlen(pZpkLmk));
    memcpy(hZpkZmk,             pZpkZmk,        strlen(pZpkZmk));
    memcpy(hCheckValue,         pCheckValue,    strlen(pCheckValue));

    EXEC SQL WHENEVER SQLERROR GOTO saveZPKKeyErr;
    EXEC SQL CONTEXT USE :tab_ParamCtx[nIndiceCtx].ctx;


    EXEC SQL EXECUTE
    BEGIN
        :hRet := PCRD_GET_HSM_KEY.SAVE_ZPK_KEY(:hResourceId, :hZpkLmk, :hZpkZmk, :hCheckValue);
    END;
    END-EXEC;

    if (hRet != OK)
    {
        sprintf(detail, "End   SaveZPKKey(NOK)");
        trace_event(detail, PROCESSING);
        return (hRet);
    }

    sprintf(detail, "End   SaveZPKKey(OK)");
    trace_event(detail, PROCESSING);
    return (OK);

saveZPKKeyErr :
    sprintf(detail, "%.79s", sqlca.sqlerrm.sqlerrmc);
    trace_event(detail, ERROR);
    trace_event("End   SaveZPKKey(ERROR)", ERROR);
    return (ERROR);
}


int     GetIssuerZPK  ( int nIndiceCtx , char *sPan, char *sZPK )
{

    struct sqlca sqlca;
    char sLine [ MAX_LINE_TRC];

	EXEC SQL BEGIN DECLARE SECTION;
        int              response;
        VARCHAR          T_Pan [22 + 1];
        VARCHAR			 T_ZPK [256 + 1];
	EXEC SQL END DECLARE SECTION;


	EXEC SQL CONTEXT USE :tab_ParamCtx[nIndiceCtx].ctx;

	trace_event("Start GetIssuerZPK()",PROCESSING);

	memset(T_ZPK.arr,        0, sizeof(T_ZPK.arr)); T_ZPK.len = 0;
	memset(T_Pan.arr, 		0, sizeof(T_Pan.arr));
	

	memcpy(T_Pan.arr, sPan, strlen(sPan));
	T_Pan.len = strlen(sPan);

	response = 909;
	EXEC SQL WHENEVER SQLERROR GOTO get_iss_zpk;
	EXEC SQL EXECUTE
	BEGIN
        :response := PCRD_GET_HSM_KEY.GET_ISSUER_ZPK(:T_Pan,
													:T_ZPK
													);
	END;
	END-EXEC;

	if (response == OK)
	{
        memcpy(sZPK, T_ZPK.arr, T_ZPK.len ); sZPK[T_ZPK.len]='\0';
		memset(T_ZPK.arr,        0, sizeof(T_ZPK.arr));
		memset(T_Pan.arr, 		0, sizeof(T_Pan.arr));
        trace_event("End   GetPinKey(OK)", PROCESSING);
        return(OK);
	}

	memset(T_ZPK.arr,        0, sizeof(T_ZPK.arr)); 
	memset(T_Pan.arr, 		0, sizeof(T_Pan.arr)); 

	trace_event("End   GetIssuerZPK(NOK)", PROCESSING);
	return(NOK);

get_iss_zpk :
    EXEC SQL WHENEVER SQLERROR CONTINUE;
	memset(T_ZPK.arr,        0, sizeof(T_ZPK.arr));
	memset(T_Pan.arr, 		0, sizeof(T_Pan.arr));

    sprintf(sLine, "%s",sqlca.sqlerrm.sqlerrmc);
    trace_event(sLine, ERROR);
    trace_event("End  GetIssuerZPK (MALFUNCTION)", PROCESSING);                                                                          
    return(HSM_MALFUNCTION);
}

/*****************************************************************************/
/* GetZMKByType                                                        	     */
/*----------------                                                           */
/*  Fonction : fonction qui recupere la cle ZMK by Type.         			*/
/*  Entree   : L'identificateur du resource.                                 */
/*  Sortie   : La cle ZMK.                                      	         */
/*****************************************************************************/

int     GetZMKByType ( int nIndiceCtx , char *resource_id, char *keyType, char *ZmK)
{
    struct sqlca sqlca;
    char sLine [ MAX_LINE_TRC];

	EXEC SQL BEGIN DECLARE SECTION;
		int		 response;
        char     T_resource_id		[ 6 + 1 ];
        char     T_keyType			[ 4 + 1 ];
        VARCHAR     T_ZmK    			[256 + 1 ]; /* TDES  04/24/03 */
	EXEC SQL END DECLARE SECTION;


	EXEC SQL CONTEXT USE :tab_ParamCtx[nIndiceCtx].ctx;
	sprintf(sLine, "Start GetZMKByType (%.6s)", resource_id);
	trace_event(sLine, PROCESSING);

	memset(T_ZmK.arr    ,       0, sizeof(T_ZmK.arr));
  T_ZmK.len = 0;
  
	memset(T_resource_id,  0, sizeof(T_resource_id));
	memset(T_keyType,  	   0, sizeof(T_keyType));
	

	memcpy(T_resource_id, resource_id, 6); 
	memcpy(T_keyType, keyType, 4); 

	sprintf(sLine, "GET_ZMK_KEY_BY_TYPE (%.6s)", T_resource_id);
	trace_event(sLine, PROCESSING);
	
	response = 909;
	EXEC SQL WHENEVER SQLERROR GOTO zmk_key_exception;
	EXEC SQL EXECUTE
	BEGIN
		:response := PCRD_GET_HSM_KEY.GET_ZMK_KEY_BY_TYPE(:T_resource_id,
							:T_keyType,
						 	:T_ZmK
							);
	END;
	END-EXEC;

	sprintf(sLine, "response :  (%d)", response);
	trace_event(sLine, PROCESSING);

	if (response == OK)
	{
        	memcpy(ZmK, T_ZmK.arr, T_ZmK.len );
			memset(T_ZmK.arr    ,       0, sizeof(T_ZmK.arr)); /* PCI */
		/*MKB060309 PCI Norme Integration */
		if (debug_option == 1)
        		sprintf(sLine, "End   GetZMKByType (%.256s)", ZmK);
		else
        		sprintf(sLine, "End   GetZMKByType (OK)");
        	trace_event(sLine, PROCESSING);        	

        	return(OK);
	}

	memset(T_ZmK.arr    ,       0, sizeof(T_ZmK.arr)); /* PCI */
	trace_event("End   GetZMKByType (NOK)", PROCESSING);
	return(NOK);

	zmk_key_exception :
    EXEC SQL WHENEVER SQLERROR CONTINUE;
	memset(T_ZmK.arr    ,       0, sizeof(T_ZmK.arr)); /* PCI */
    sprintf(sLine, "%s",sqlca.sqlerrm.sqlerrmc);
    trace_event(sLine, ERROR);                                                                                                     
    trace_event("End  GetZMKByType(MALFUNCTION)", PROCESSING);                                                                           
    return(HSM_MALFUNCTION);

}


