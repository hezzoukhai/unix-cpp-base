/*****************************************************************************/
/* GetAWK                                                        	         */
/*----------------                                                           */
/*  Fonction : fonction qui recupere les cles AwK.                           */
/*  Entree   : L'identificateur du resource.                                */
/*             La banque acquireur.                             	         */
/*  Sortie   : La cle AwK.                                      	         */
/*****************************************************************************/
int  Get_AWK( int nIndiceCtx, char *resource_id,  char *AwK, char* check_value )
{
    struct sqlca sqlca;
    char sLine [ MAX_LINE_TRC];

	EXEC SQL BEGIN DECLARE SECTION;
		int			response;
        char		T_resource_id		[ 6 + 1];
        varchar     T_AwK  				[256 + 1];
		varchar     T_check_value  		[256 + 1];
	EXEC SQL END DECLARE SECTION;

	sprintf(sLine, "Start Get_AWK(%.6s)", resource_id);
	trace_event(sLine, PROCESSING);

	EXEC SQL CONTEXT USE :tab_ParamCtx[nIndiceCtx].ctx;
	memset(T_AwK.arr ,       0, sizeof(T_AwK.arr    ));
	T_AwK.len = 0;
	memset(T_check_value.arr ,       0, sizeof(T_check_value.arr    ));
	T_check_value.len = 0;
	memset(T_resource_id,  0, sizeof(T_resource_id));
	memcpy(T_resource_id, resource_id, 6);


	response = 909;
	EXEC SQL WHENEVER SQLERROR GOTO awk_key_exception;
	EXEC SQL EXECUTE
	BEGIN
		:response := PCRD_GET_HSM_KEY.GET__AWK__KEY(	:T_resource_id,
						 								:T_AwK,
														:T_check_value
													);
	END;
	END-EXEC;

	if (response == OK)
	{
		memcpy(AwK    , T_AwK.arr    , T_AwK.len );
		memcpy(check_value    , T_check_value.arr    , T_check_value.len );
		memset(T_AwK.arr ,         0, sizeof(T_AwK.arr    ));
		memset(T_check_value.arr , 0, sizeof(T_check_value.arr    ));
		if (debug_option == 1)
			sprintf(sLine, "End   Get_AWK(%.256s)[%s]", AwK,check_value);
		else
			sprintf(sLine, "End   Get_AWK(OK)[%s]",check_value);
		trace_event(sLine, PROCESSING);	
		return(OK);
	}

	trace_event("End   Get_AWK(NOK)", PROCESSING);
	return(NOK);

awk_key_exception :
    EXEC SQL WHENEVER SQLERROR CONTINUE;
	memset(T_AwK.arr ,         0, sizeof(T_AwK.arr    ));
	memset(T_check_value.arr , 0, sizeof(T_check_value.arr    ));
    sprintf(sLine, "%s",sqlca.sqlerrm.sqlerrmc);
    trace_event(sLine, ERROR);
    trace_event("End  Get_AWK (MALFUNCTION)", PROCESSING);
    return(HSM_MALFUNCTION);

}

/*****************************************************************************/
/* GetIWK                                                        	         */
/*----------------                                                           */
/*  Fonction : fonction qui recupere les cles IwK.                           */
/*  Entree   : L'identificateur du resource.                                 */
/*             La banque acquireur.                             	         */
/*  Sortie   : La cle IwK.                                      	         */
/*****************************************************************************/

int     Get_IWK( int nIndiceCtx, char *resource_id , char *IwK, char* check_value  )
{

    	struct sqlca sqlca;
    	char sLine [ MAX_LINE_TRC];

	EXEC SQL BEGIN DECLARE SECTION;
		int	 response;
        char		T_resource_id		[ 6 + 1 ];
        varchar		T_IwK				[256 + 1 ];
		varchar     T_check_value  		[256 + 1];
	EXEC SQL END DECLARE SECTION;


	EXEC SQL CONTEXT USE :tab_ParamCtx[nIndiceCtx].ctx;
	sprintf(sLine, "Start Get_IWK(%.6s)", resource_id);
	trace_event(sLine, PROCESSING);

	memset(T_IwK.arr    ,  0, sizeof(T_IwK.arr));
	T_IwK.len = 0;
	memset(T_check_value.arr    ,  0, sizeof(T_check_value.arr));
	T_check_value.len = 0;
	memset(T_resource_id,  0, sizeof(T_resource_id));

	memcpy(T_resource_id, resource_id, 6);

	response = 909;
	EXEC SQL WHENEVER SQLERROR GOTO iwk_key_exception;
	EXEC SQL EXECUTE
	BEGIN
		:response := PCRD_GET_HSM_KEY.GET__IWK__KEY(:T_resource_id,
													:T_IwK,
													:T_check_value);
	END;
	END-EXEC;

	if (response == OK)
	{
		memcpy(IwK, T_IwK.arr, T_IwK.len );
		memcpy(check_value, T_check_value.arr, T_check_value.len );
		memset(T_IwK.arr    ,  0, sizeof(T_IwK.arr));
		if (debug_option == 1)
			sprintf(sLine, "End   Get_IWK(%.256s)[%s]", IwK,check_value);
		else
        	sprintf(sLine, "End   Get_IWK(OK)[%s]",check_value);
        trace_event(sLine, PROCESSING);
        return(OK);
	}

	trace_event("End   Get_IWK(NOK)", PROCESSING);
	return(NOK);


 iwk_key_exception :
    EXEC SQL WHENEVER SQLERROR CONTINUE;
	memset(T_IwK.arr    ,  0, sizeof(T_IwK.arr));
    sprintf(sLine, "%s",sqlca.sqlerrm.sqlerrmc);
    trace_event(sLine, ERROR);
    trace_event("End  Get_IWK (MALFUNCTION)", PROCESSING);
    return(HSM_MALFUNCTION);

}


/*****************************************************************************/
/* GetMAC                                                                    */
/*----------------                                                           */
/*  Fonction : fonction qui recupere la cle MAC.                             */
/*  Entree   : Le numero de terminal.                                        */
/*  Sortie   : La cle MAC.                                                   */
/*****************************************************************************/

int     GetMAC( int nIndiceCtx ,
		char *terminal_number, 
		char *V_AcqBank, /*ICH270715*/
		char type,
		char *MAC1,
		char *MAC2 )
{

    struct sqlca sqlca;
    char sLine [ MAX_LINE_TRC];

	EXEC SQL BEGIN DECLARE SECTION;
        int              response;
        VARCHAR          T_terminal_number 	[15 + 1];
        VARCHAR      			T_AcqBank  	 	[6+1];/*ICH270715*/ 
        varchar             T_MAC1         	[256 + 1];
        varchar             T_MAC2         	[256 + 1];
        char             T_type [1+1]     ; 
	EXEC SQL END DECLARE SECTION;


	EXEC SQL CONTEXT USE :tab_ParamCtx[nIndiceCtx].ctx;
	sprintf(sLine,"Debut GetMAC(%c,%s,%s)",type,terminal_number,V_AcqBank);
	trace_event(sLine,PROCESSING);

	memset(T_MAC1.arr,        0, sizeof(T_MAC1));
	memset(T_MAC2.arr,        0, sizeof(T_MAC2));
	memset(T_type, 0, sizeof(T_type));
	memset(T_terminal_number.arr, 0, sizeof(terminal_number));
	T_terminal_number.len = 15;
	memset(T_AcqBank.arr,	0, sizeof(T_AcqBank.arr));/*ICH270715*/ 
	
        T_MAC1.len=0;
        T_MAC2.len=0;
	memcpy(T_terminal_number.arr, terminal_number, strlen(terminal_number));
	T_terminal_number.len = strlen(terminal_number);
		
	memcpy(T_AcqBank.arr, V_AcqBank, strlen(V_AcqBank));
	T_AcqBank.len = strlen(V_AcqBank);
	
	T_type[0] = type; 

	response = 909;
	EXEC SQL WHENEVER SQLERROR GOTO mac_key_exception;
 	EXEC SQL EXECUTE
	BEGIN
#if defined(FO_ATM_ST_CORE) || defined(FO_ATM_SA_CORE)
		IF :T_type IN ('T','R')
		THEN
			:response := PCRD_ATM_GET_HSM_KEY.GET_MAC_KEY(
													:T_terminal_number,
													:T_AcqBank,/*ICH270715*/  
													:T_type,
													:T_MAC1,
													:T_MAC2
													 );
		ELSE
			NULL;
#endif

#if defined(FO_POS_ST_CORE) || defined(FO_POS_SA_CORE)
		IF :T_type IN ('P','R')
		THEN
			:response := PCRD_POS_GET_HSM_KEY.GET_MAC_KEY(
													:T_terminal_number,
													:T_type,
													:T_MAC1,
													:T_MAC2
													 );
		ELSE
			NULL;
#endif

		:response := PCRD_GET_HSM_KEY.GET_MAC_KEY(
												:T_terminal_number,
												:T_MAC1,
												:T_MAC2
													);

#if defined(FO_POS_ST_CORE) || defined(FO_POS_SA_CORE)
	END IF;
#endif
#if defined(FO_ATM_ST_CORE) || defined(FO_ATM_SA_CORE)
	END IF;
#endif

	END;
	END-EXEC;

	if (response == OK)
	{
        	memcpy(MAC1, T_MAC1.arr, T_MAC1.len );
        	memcpy(MAC2, T_MAC2.arr, T_MAC2.len );
		/*MKB060309 PCI Norme Integration */
		if (debug_option == 1)
		{
			sprintf(sLine,"-->MAC1 : %s,MAC2 : %s",MAC1,MAC2);
			trace_event(sLine,PROCESSING);
		}
		memset(T_MAC1.arr,        0, sizeof(T_MAC1));
		memset(T_MAC2.arr,        0, sizeof(T_MAC2));
        	trace_event("Fin   GetMAC(OK)", PROCESSING);
        	return(OK);
	}

	memset(T_MAC1.arr,        0, sizeof(T_MAC1));
	memset(T_MAC2.arr,        0, sizeof(T_MAC2));
	trace_event("Fin   GetMAC(NOK)", PROCESSING);
	return(NOK);

	mac_key_exception :
    EXEC SQL WHENEVER SQLERROR CONTINUE;                                                                                           
	memset(T_MAC1.arr,        0, sizeof(T_MAC1));
	memset(T_MAC2.arr,        0, sizeof(T_MAC2));
    sprintf(sLine, "%s",sqlca.sqlerrm.sqlerrmc);
    trace_event(sLine, ERROR);
    trace_event("End  GetMAC (MALFUNCTION)", PROCESSING);
    return(HSM_MALFUNCTION);

}

/*****************************************************************************/
/* GetPinKey                                                                 */
/*------------                                                               */
/*  Fonction : fonction qui recupere la cle TAK1 prise en tant que PVK_KEY   */
/*              et la cle TAK2 en tant que cle PIN pour le GAB SNI.          */
/*  Entree   : Le numero du terminal.                                        */
/*****************************************************************************/

int     GetPinKey  ( int nIndiceCtx , char *sPan, char *PinKey )
{

    struct sqlca sqlca;
    char sLine [ MAX_LINE_TRC];

	EXEC SQL BEGIN DECLARE SECTION;
        int              response;
        VARCHAR          T_Pan [22 + 1];
        VARCHAR        T_PinKey [256 + 1]; /* TDES */
	EXEC SQL END DECLARE SECTION;


	EXEC SQL CONTEXT USE :tab_ParamCtx[nIndiceCtx].ctx;
	trace_event("Debut GetPinKey  ",PROCESSING);

	memset(T_PinKey.arr,        0, sizeof(T_PinKey.arr));
	memset(T_Pan.arr, 		0, sizeof(T_Pan.arr));
	T_Pan.len = 22;

	memcpy(T_Pan.arr, sPan, strlen(sPan));
	T_Pan.len = strlen(sPan);

	response = 909;
	EXEC SQL WHENEVER SQLERROR GOTO pin_key_exception;
	EXEC SQL EXECUTE
	BEGIN
        :response := PCRD_GET_HSM_KEY.GET_PIN_KEY(:T_Pan,
                                                 :T_PinKey
                                                 );
	END;
	END-EXEC;

	if (response == OK)
	{
        memcpy(PinKey, T_PinKey.arr, T_PinKey.len );
		memset(T_PinKey.arr,        0, sizeof(T_PinKey.arr)); /*PCI */
		memset(T_Pan.arr, 		0, sizeof(T_Pan.arr));        /*PCI */
        trace_event("Fin   GetPinKey(OK)", PROCESSING);
        return(OK);
	}

	memset(T_PinKey.arr,        0, sizeof(T_PinKey.arr)); /*PCI */
	memset(T_Pan.arr, 		0, sizeof(T_Pan.arr));        /*PCI */
	trace_event("Fin   GetPinKey(NOK)", PROCESSING);
	return(NOK);

	pin_key_exception :
    EXEC SQL WHENEVER SQLERROR CONTINUE;
	memset(T_PinKey.arr,        0, sizeof(T_PinKey.arr)); /*PCI */
	memset(T_Pan.arr, 		0, sizeof(T_Pan.arr));        /*PCI */
    sprintf(sLine, "%s",sqlca.sqlerrm.sqlerrmc);
    trace_event(sLine, ERROR);
    trace_event("End  GetPinKey (MALFUNCTION)", PROCESSING);                                                                          
    return(HSM_MALFUNCTION);

}

/*****************************************************************************/
/* GetAwkZmk                                                	             */
/*----------------                                                           */
/*  Fonction : fonction qui recupere la cle AwK encrypte sous ZMK .          */
/*  Entree   : L'identificateur du resource.                                 */
/*             La banque acquireur.                             	         */
/*  Sortie   : La cle AwK.                                      	         */
/*****************************************************************************/

int     GetAwkZmk  ( int nIndiceCtx , char *resource_id, char *AwK )
{

    struct sqlca sqlca;
    char sLine [ MAX_LINE_TRC];

	EXEC SQL BEGIN DECLARE SECTION;
		int		 response;
        char             T_resource_id	[ 6 + 1];
        varchar             T_AwK   	[256 + 1]; /* TDES */
	EXEC SQL END DECLARE SECTION;


	EXEC SQL CONTEXT USE :tab_ParamCtx[nIndiceCtx].ctx;
	sprintf(sLine, "Start GetAwkZmk(%.6s)", resource_id);
	trace_event(sLine, PROCESSING);

	memset(T_AwK.arr    ,       0, sizeof(T_AwK.arr ));
	memset(T_resource_id,   0, sizeof(T_resource_id));

	memcpy(T_resource_id, resource_id, 6);

	response = 909;
	EXEC SQL WHENEVER SQLERROR GOTO awk_key_exception;
	EXEC SQL EXECUTE
	BEGIN
		:response := PCRD_GET_HSM_KEY.GET_AWK_KEY_UNDER_ZMK(	:T_resource_id,
						 									:T_AwK    
														   );
	END;
	END-EXEC;

	if (response == OK)
	{
        	memcpy(AwK    , T_AwK.arr  , T_AwK.len );
		/*MKB060309 PCI Norme Integration */
		memset(T_AwK.arr    ,       0, sizeof(T_AwK.arr ));
		if (debug_option == 1)
        		sprintf(sLine, "End   GetAwkZmk(%.16s)", AwK    );
		else
        		sprintf(sLine, "End   GetAwkZmk(OK)");
        	trace_event(sLine, PROCESSING);
        	
        	return(OK);
	}

	memset(T_AwK.arr    ,       0, sizeof(T_AwK.arr ));
	trace_event("End   GetAwkZmk(NOK)", PROCESSING);
	return(NOK);


	awk_key_exception :
    EXEC SQL WHENEVER SQLERROR CONTINUE;                                                                                           
	memset(T_AwK.arr    ,       0, sizeof(T_AwK.arr ));	
    sprintf(sLine, "%s",sqlca.sqlerrm.sqlerrmc);
    trace_event(sLine, ERROR);
    trace_event("End  GetAwkZmk (MALFUNCTION)", PROCESSING);                                                                       

    return(HSM_MALFUNCTION);

}

/** START MAW20030525: For Take Other PVK for PVV Verif **/

int GetPVKPinKey( int nIndiceCtx, char *sPan, char *PVKA ,char *PVKB )
{
    struct sqlca sqlca;
    char sLine [ MAX_LINE_TRC];

        EXEC SQL BEGIN DECLARE SECTION;
        int              response;
        VARCHAR          T_Pan  [22 + 1];
		varchar          T_PVKA [256 + 1];
    	varchar          T_PVKB [256 + 1];
		varchar          T_LMK_ID [12 + 1];
        int              T_PVKI;
        EXEC SQL END DECLARE SECTION;


        EXEC SQL CONTEXT USE :tab_ParamCtx[nIndiceCtx].ctx;
	
	if (debug_option == 1)
        	sprintf(sLine, "Start GetPVKPinKey(%.16s)", sPan);
	else
        	sprintf(sLine, "Start GetPVKPinKey()");
        trace_event(sLine, PROCESSING);
	

        memset( T_PVKA.arr,        	0, sizeof(T_PVKA.arr)); T_PVKA.len = 0;
		memset( T_PVKB.arr,        	0, sizeof(T_PVKB.arr)); T_PVKB.len = 0;
		memset(T_LMK_ID.arr,    0, sizeof(T_LMK_ID.arr)); T_LMK_ID.len = 0;
        memset( T_Pan.arr,              0, sizeof(T_Pan.arr));
        T_Pan.len = 22;
    	T_PVKI = 0;

        memcpy( T_Pan.arr, sPan, strlen(sPan) );
        T_Pan.len = strlen(sPan);
	
	if (debug_option == 1)
	{
        	sprintf(sLine, "T_Pan.arr=[%s], T_Pan.len=[%d])", T_Pan.arr, T_Pan.len);
        	trace_event(sLine, PROCESSING);
	}
	else
	{
			sprintf(sLine, "T_Pan.arr=[**********], T_Pan.len=[%d])", T_Pan.len);
        	trace_event(sLine, PROCESSING);
	}
        response = 909;
        EXEC SQL WHENEVER SQLERROR GOTO pvk_key_exception;
        EXEC SQL EXECUTE
        BEGIN
        :response := PCRD_GET_HSM_KEY.GET_PVK_KEY (       	:T_Pan   ,
                                                                :T_PVKA  ,
                                                                :T_PVKB,
																:T_LMK_ID
                                                        );
        END;
        END-EXEC;

        if (response == OK)
        {
			memcpy(PVKA, T_PVKA.arr, T_PVKA.len );
        	memcpy(PVKB, T_PVKB.arr, T_PVKB.len );	
			memset( T_PVKA.arr,        	0, sizeof(T_PVKA.arr));
			memset( T_PVKB.arr,        	0, sizeof(T_PVKB.arr));
			memset( T_Pan.arr,      0, sizeof(T_Pan.arr));
		if (debug_option == 1)
        		sprintf(sLine, "End   GetPVKPinKey(%.16s,%.16s)", PVKA, PVKB);
		else
			sprintf(sLine, "End   GetPVKPinKey(OK)");
		trace_event(sLine, PROCESSING);
		
        	return(OK);
        }

        memset( T_PVKA.arr,        	0, sizeof(T_PVKA.arr));
		memset( T_PVKB.arr,        	0, sizeof(T_PVKB.arr));
        memset( T_Pan.arr,      0, sizeof(T_Pan.arr));
        trace_event("End   GetPVKPinKey(NOK)", PROCESSING);
        return(NOK);

    pvk_key_exception :
    EXEC SQL WHENEVER SQLERROR CONTINUE;
	memset( T_PVKA.arr,        	0, sizeof(T_PVKA.arr));
	memset( T_PVKB.arr,        	0, sizeof(T_PVKB.arr));
	memset( T_Pan.arr,      0, sizeof(T_Pan.arr));
    sprintf(sLine, "%s",sqlca.sqlerrm.sqlerrmc);
    trace_event(sLine, ERROR);
    trace_event("End  GetPVKPinKey(MALFUNCTION)", PROCESSING);
    return(HSM_MALFUNCTION);

}

/*****************************************************************************/
/* GetResourceTMK                                                            */
/*----------------                                                           */
/*  Fonction : fonction qui recupere la cle TMK.                             */
/*  Entree   : L'identificateur du resource.                                */
/*  Sortie   : La cle TMK.                                                   */
/*****************************************************************************/

int     GetResourceTMK ( int nIndiceCtx , char *resource_id, char *TmK)
{
    struct sqlca sqlca;
    char sLine [ MAX_LINE_TRC];

    EXEC SQL BEGIN DECLARE SECTION;
        int      response;
        char     T_resource_id      [ 6 + 1 ];
        VARCHAR  T_TmK              [256 + 1 ];
    EXEC SQL END DECLARE SECTION;


    EXEC SQL CONTEXT USE :tab_ParamCtx[nIndiceCtx].ctx;

    memset(T_TmK.arr    ,       0, sizeof(T_TmK.arr));
    T_TmK.len = 0;

        memset(T_resource_id,  0, sizeof(T_resource_id));
    memcpy(T_resource_id, resource_id, 6);

    sprintf(sLine, "Start GetResourceTMK (%.6s)", T_resource_id);
    trace_event(sLine, PROCESSING);

    response = 909;
    EXEC SQL WHENEVER SQLERROR GOTO tmk_key_exception;
    EXEC SQL EXECUTE
    BEGIN
        :response := PCRD_GET_HSM_KEY.GET_RES_TMK_KEY(  :T_resource_id,
                                                                                :T_TmK);
    END;
    END-EXEC;

    sprintf(sLine, "response :  (%d)", response);
    trace_event(sLine, PROCESSING);

    if (response == OK)
    {
        memcpy(TmK, T_TmK.arr, T_TmK.len );
	/*MKB060309 PCI Norme Integration */
	memset(T_TmK.arr    ,       0, sizeof(T_TmK.arr));
	if (debug_option == 1)
        	sprintf(sLine, "End   GetResourceTMK (%.256s)", TmK);
        else
         	sprintf(sLine, "End   GetResourceTMK (OK)");
        trace_event(sLine, PROCESSING);       	
        
        return(OK);
    }

	memset(T_TmK.arr    ,       0, sizeof(T_TmK.arr));
    trace_event("End   GetResourceTMK (NOK)", PROCESSING);
    return(NOK);

    tmk_key_exception :
    EXEC SQL WHENEVER SQLERROR CONTINUE;
	memset(T_TmK.arr    ,       0, sizeof(T_TmK.arr));
    sprintf(sLine, "%s",sqlca.sqlerrm.sqlerrmc);
    trace_event(sLine, ERROR);
    trace_event("End  GetResourceTMK(MALFUNCTION)", PROCESSING);
    return(HSM_MALFUNCTION);

}


