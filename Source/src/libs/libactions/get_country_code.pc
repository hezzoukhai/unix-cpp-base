/****************************************************************************/
/****************************************************************************/
/*NAB05042021 PLUTONL-2944*/
int  GetMcEpiArea (int  nIndexCtx, char * sAcqCountry,char* sMcEpiArea)
{

   EXEC SQL BEGIN DECLARE SECTION;
                char       sLine[MAX_LINE_TRC];
        char       T_AcqCountry         [3+1];
        char       T_Mc_Area_Code       [4+1];
        int        result;

   EXEC SQL END DECLARE SECTION;

   trace_event ("Start  GetMciEpiArea()", PROCESSING);

   memset(T_AcqCountry,0,sizeof(T_AcqCountry));
   memset(T_Mc_Area_Code,0,sizeof(T_Mc_Area_Code));

   strncpy (T_AcqCountry, sAcqCountry,3);




   EXEC SQL CONTEXT USE :tab_ParamCtx[nIndexCtx].ctx;
   EXEC SQL WHENEVER SQLERROR GOTO get_area_code_mc_err;
   EXEC SQL EXECUTE
   BEGIN
                :result := PCRD_GENERAL_TOOLS_5.GET_AREA_CODE_MC ( :T_AcqCountry,:T_Mc_Area_Code);
   END;
   END-EXEC;

   if (result == OK)
   {
      memcpy(sMcEpiArea,T_Mc_Area_Code,1);

          sprintf(sLine,"End GetMciEpiArea(OK) sMcEpiArea[%s]",sMcEpiArea);
          trace_event (sLine, PROCESSING);
      return (OK) ;
   }
   else
   {
      trace_event ("End GetMciEpiArea(NOK)", PROCESSING);
      return (NOK);
   }

get_area_code_mc_err:
      sprintf(sLine, "%s", sqlca.sqlerrm.sqlerrmc);
      trace_event(sLine, FATAL);

      trace_event ("End GetMciEpiArea (ERROR)", PROCESSING);
      return (NOK);
}