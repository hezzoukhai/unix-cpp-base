#include <stdio.h>
#include <define.h>

#include <param_ctx.h>

#include <sqlca.h>
#include <sqlcpr.h>

int  GetBridgeResourceId (int  nIndexCtx, char  *sSrcNodeId, char  *sSrcResourceId, pid_t* nSrcPid )
{
	struct sqlca sqlca;
	char sLine [ MAX_LINE_TRC];
	
   EXEC SQL BEGIN DECLARE SECTION;
        char       T_src_node_id			[4 + 1];
        char       T_resource_id			[6 + 1];
		pid_t	   T_pid;
        int        result;
   EXEC SQL END DECLARE SECTION;

   sprintf (sLine,"Start  GetBridgeResourceId(%s)", sSrcNodeId);
   trace_event (sLine, PROCESSING);

   memset (T_src_node_id,       0, sizeof(T_src_node_id));
   memset (T_resource_id,        0, sizeof(T_resource_id));
   T_pid =  -1;

   memcpy (T_src_node_id, sSrcNodeId, 4);
   
   

   EXEC SQL CONTEXT USE :tab_ParamCtx[nIndexCtx].ctx; 
   EXEC SQL WHENEVER SQLERROR GOTO get_bridge_res_id_err;
   EXEC SQL EXECUTE  
   BEGIN
      :result := PCRD_P7_BRIDGE.GET_BRIDGE_RESOURCE_ID (
															:T_src_node_id,
															:T_resource_id,
															:T_pid);

   END;
   END-EXEC;

   *nSrcPid = T_pid;

   if (result == OK && kill ( T_pid , 0 ) != 0 )
   {
	   result = NOK;
   }

   if( result == OK )
   {
      memcpy (sSrcResourceId,    T_resource_id,   6);
	  sSrcResourceId[6]='\0';
	  sprintf(sLine,"End GetBridgeResourceId(OK): [%s,%d]",sSrcResourceId,*nSrcPid);
      trace_event (sLine, PROCESSING);
      return (OK);
   }
   else
   {
      trace_event ("End GetBridgeResourceId(NOK)", PROCESSING);
      return (NOK);
   }

get_bridge_res_id_err:   
	EXEC SQL WHENEVER SQLERROR CONTINUE;
	sprintf(sLine, "%s",sqlca.sqlerrm.sqlerrmc);
	trace_event(sLine, ERROR);
	trace_event ("End GetBridgeResourceId (NOK)", PROCESSING);
	return (NOK);
}

