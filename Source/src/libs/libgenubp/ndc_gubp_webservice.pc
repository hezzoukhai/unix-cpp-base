/****************************************Reply Data**********************************/

/*****************************************************************************/
/* Fonction Get_UBP_ReplyData                                                     */
/* ----------------------------------------                                  */
/*  Fonction : La fonction Get_UBP_ReplyData() cherche l'etat suivant du GAB en se*/
/*             basant                                                        */
/*             sur le RESPONSE CODE, CURRENT TRANSACTION et NEXT TRANSACTION.*/
/*             En consultant la table ATM_REPLY_SWITCH, si la fonction ne    */
/*             trouve aucun enregistrement correspondant au triplet          */
/*             (pRepCode, pCurTrn, pNextTrn), alors elle retourne le triplet*/
/*             (NEXT_STATE, SCREEN_NUMBER, UPDATE_SCREEN_NUMBER) par defaut  */
/*  Entree   : Le code reponse                                               */
/*             Le code de la transaction courrante                           */
/*             Le code de la prochaine transaction                           */
/*  Sortie   : La next state                                                 */
/*             La screen number                                              */
/*             La update_screen_number                                       */ 
/*  Retour   : OK                                                            */
/*  Revision :                                                               */
/*****************************************************************************/
int     Get_UBP_ReplyData(nIndexCtx,
/*NOT USED*/
pRepCode,
pCurTrn,
pNextTrn,
pTerminalNumber,
pAcqBank,
pNextState,
pScrNbr,
pUpScrNbr,
Card_type_flag
)
int    nIndexCtx;
int    pRepCode;
int    pCurTrn;
int    pNextTrn;
char   *pTerminalNumber; /**IDA22012015**/
char   *pAcqBank; /**IDA22012015**/
char   *pNextState;
char   *pScrNbr;
char   *pUpScrNbr;
char   *Card_type_flag;

{
	struct sqlca sqlca; /*MK 060606*/
	char ligne[MAX_LINE_TRC];
	EXEC SQL BEGIN DECLARE SECTION;
	int		T_pRepCode;
	int		T_pCurTrn;
	int		T_pNextTrn;	
	VARCHAR	T_pTerminalNumber[15 + 1];		/**IDA22012015**/
	VARCHAR	T_AcqBank[6 + 1];		/**ICH270715**/	
	char    T_pNextState	[3+1];
	char    T_pScrNbr		[3+1];
	char    T_pUpScrNbr		[3+1];
	VARCHAR T_Card_type_flag	[1+1];
	int	plRetour;
	EXEC SQL END DECLARE SECTION;

	sprintf(ligne, "Start Get_UBP_ReplyData(%d,%d,%d,%s,%s,%s)", pRepCode, pCurTrn, pNextTrn, Card_type_flag,pTerminalNumber,pAcqBank);
	trace_event(ligne, PROCESSING);

	memset(T_pNextState, 0,sizeof(T_pNextState));
	memset(T_pScrNbr,    0,sizeof(T_pScrNbr));
	memset(T_pUpScrNbr,  0,sizeof(T_pUpScrNbr));
	memset( T_Card_type_flag.arr            ,  0  ,   sizeof(T_Card_type_flag.arr )  );
	T_Card_type_flag.len = 0;
	memset(T_AcqBank.arr,	0, sizeof(T_AcqBank.arr)	);/*ICH270715*/


	memcpy ( T_Card_type_flag.arr     , Card_type_flag ,   strlen(Card_type_flag )  );
	T_Card_type_flag.len = strlen(Card_type_flag);
	memcpy ( T_pTerminalNumber.arr     , pTerminalNumber ,   strlen(pTerminalNumber )  );/**IDA22012015**/
	T_pTerminalNumber.len = strlen(pTerminalNumber);/**IDA22012015**/
	memcpy(T_AcqBank.arr,	pAcqBank, strlen(pAcqBank)	);/*ICH270715*/
	T_AcqBank.len = strlen(pAcqBank);

	T_pRepCode = pRepCode;	
	T_pCurTrn   = pCurTrn;
	T_pNextTrn  = pNextTrn;

	plRetour = NOK;

	sprintf(ligne, "Get_UBP_ReplyData(%d,%d,%d,%s)", pRepCode, pCurTrn, pNextTrn, Card_type_flag);
	trace_event(ligne, PROCESSING);

	EXEC SQL CONTEXT USE :tab_ParamCtx[nIndexCtx].ctx;
	EXEC SQL EXECUTE

	BEGIN
	NULL;
	END;
	END-EXEC;

	if(plRetour == OK)
	{
		memcpy(pNextState, T_pNextState, sizeof(T_pNextState));
		memcpy(pScrNbr, T_pScrNbr, sizeof(T_pScrNbr));
		memcpy(pUpScrNbr, T_pUpScrNbr, sizeof(T_pUpScrNbr));
		sprintf(ligne, "END   Get_UBP_ReplyData(%s,%s,%s)", pNextState, pScrNbr, pUpScrNbr);
		trace_event(ligne, PROCESSING);


		return(OK);
	}

	trace_event("END   Get_UBP_ReplyData(FATAL)", PROCESSING);
	return(NOK);

}
