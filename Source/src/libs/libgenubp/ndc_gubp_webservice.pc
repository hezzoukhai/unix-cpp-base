#include <event_auth.h>*/

#include <sqlca.h>
#include <sqlcpr.h>

#include <tlv_private.h>
#include <tlv_fields.h>



int fetch_input_count  ( int nIndiceCtx ,char *pAcqBank , char  *OpCode, char* sServiceType, int *Utility_input_count )
{
	struct sqlca sqlca;
	char sLine 		 [ MAX_LINE_TRC];

	EXEC SQL BEGIN DECLARE SECTION;
	
	int       hUtility_input_count;
	int		    response_code;
	VARCHAR		T_service_type[1 + 1];
	EXEC SQL END DECLARE SECTION;

	EXEC SQL CONTEXT USE :tab_ParamCtx[nIndiceCtx].ctx;

	sprintf(sLine,"Start fetch_input_count [%s][%s])", OpCode,pAcqBank );
	trace_event ( sLine, PROCESSING );

	memset ( T_service_type.arr            ,  0  ,   sizeof(T_service_type.arr )  );
	T_service_type.len = 0;

	/****************************************************************************/
	/*      Appel PL/SQL                                                       */
	/****************************************************************************/
	response_code = SYSTEM_MALFUNCTION;
	EXEC SQL WHENEVER SQLERROR GOTO err_UbpInquiry;
	EXEC SQL EXECUTE
	BEGIN
	:response_code := PCRD_UBP_TOOLS.GET_INPUT_COUNT( :pAcqBank , :OpCode,:T_service_type, :hUtility_input_count  ); 
	END;
	END-EXEC;
	
	if( response_code == OK )
	{
		*Utility_input_count  = hUtility_input_count;
		sServiceType[0] = T_service_type.arr[0];
	}
	else
	{
		*Utility_input_count  = 0;
	}



	sprintf(sLine,"End   fetch_input_count (%d, count(%d))", response_code, *Utility_input_count);
	trace_event(sLine,PROCESSING);
	return(response_code);

	err_UbpInquiry :
	EXEC SQL WHENEVER SQLERROR CONTINUE;
	
	sprintf(sLine, "%.40s",sqlca.sqlerrm.sqlerrmc);
	trace_event (  sLine , ERROR );
	trace_event("End fetch_input_count (SYSTEM_MALFUNCTION)", PROCESSING);
	trace_event("DETAILS", PROCESSING);
	
	return( SYSTEM_MALFUNCTION );
}


int fetch_input_screen  (			int nIndiceCtx , 								
									char *pAcqBank, 
									char *Utility_id, 
									int input_number, 
									char *pTransLang , 
									char *pInputScreen, 
									char* input_type)
{
	struct sqlca sqlca;
	char sLine 		 [ MAX_LINE_TRC];

	EXEC SQL BEGIN DECLARE SECTION;
	VARCHAR   	T_pInputScreen	  [ 3 + 1]; 	
	VARCHAR   	T_pTransLang	  [ 12 + 1];
	VARCHAR   	T_pInputType	  [ 1 + 1]; 
	int		    response_code;
	EXEC SQL END DECLARE SECTION;

	EXEC SQL CONTEXT USE :tab_ParamCtx[nIndiceCtx].ctx;

	sprintf(sLine,"Start fetch_input_screen [%s])", Utility_id); 
	trace_event ( sLine, PROCESSING );

	/****************************************************************************/
	/*      INITIALISATION                                                      */
	/****************************************************************************/
	memset ( T_pInputScreen.arr            ,  0  ,   sizeof(T_pInputScreen.arr )  );
	T_pInputScreen.len = 0;
	
	memset ( T_pTransLang.arr            ,  0  ,   sizeof(T_pTransLang.arr )  );
	T_pTransLang.len = 0; 

	memset ( T_pInputType.arr            ,  0  ,   sizeof(T_pInputType.arr )  );
	T_pInputType.len = 0; 

	memcpy ( T_pTransLang.arr     ,  pTransLang   ,   strlen(pTransLang )  );
	T_pTransLang.len = strlen(pTransLang );
	
	/****************************************************************************/
	/*      Appel PL/SQL                                                       */
	/****************************************************************************/
	response_code = SYSTEM_MALFUNCTION;
	EXEC SQL WHENEVER SQLERROR GOTO err_UbpInquiry;
	EXEC SQL EXECUTE 
	BEGIN
	:response_code := PCRD_UBP_TOOLS.GET_INPUT_SCREEN(	:pAcqBank , 															
	:Utility_id, 
	:input_number, 
	:T_pTransLang,
	:T_pInputScreen,																	
	:T_pInputType ); 
	END;
	END-EXEC;
	
	if( response_code == OK )
	{ 
		memcpy(pInputScreen, T_pInputScreen.arr, 3);
		input_type[0] = T_pInputType.arr[0];
	}
	

	sprintf(sLine,"End fetch_input_screen (%d: scr:[%s], action [%c])", response_code,pInputScreen,input_type[0]);
	trace_event(sLine,PROCESSING);
	return(response_code);

	err_UbpInquiry :
	EXEC SQL WHENEVER SQLERROR CONTINUE;
	
	sprintf(sLine, "%.40s",sqlca.sqlerrm.sqlerrmc);
	trace_event (  sLine , ERROR );
	trace_event("End fetch_input_screen (SYSTEM_MALFUNCTION)", PROCESSING);
	trace_event("DETAILS", PROCESSING);
	
	return( SYSTEM_MALFUNCTION );
}


int get_utility_by_oc  (			int nIndiceCtx , 
						char *plProfileCode,
						char *pAcqBank, 
						int pOp_code,
						char *pMaster_idx,
						char *pUtility_id									
							) 
{
	struct sqlca sqlca; 
	char sLine 		 [ MAX_LINE_TRC];

	EXEC SQL BEGIN DECLARE SECTION;
	VARCHAR   	T_pUtility_id	  [ 30 + 1]; 
	VARCHAR   	T_pOp_code	      [ 4 + 1]; 
	int		    response_code;
	EXEC SQL END DECLARE SECTION;

	EXEC SQL CONTEXT USE :tab_ParamCtx[nIndiceCtx].ctx;

	sprintf(sLine,"Start get_utility_by_oc [%d] plProfileCode[%s])", pOp_code,plProfileCode);
	trace_event ( sLine, PROCESSING );

	/****************************************************************************/
	/*      INITIALISATION                                                      */
	/****************************************************************************/
	memset ( T_pUtility_id.arr            ,  0  ,   sizeof(T_pUtility_id.arr )  );
	T_pUtility_id.len = 0;
	memset ( T_pOp_code.arr            ,  0  ,   sizeof(T_pOp_code.arr )  );
	T_pOp_code.len = 0;
	/****************************************************************************/
	/*      Appel PL/SQL                                                       */
	/****************************************************************************/
	response_code = SYSTEM_MALFUNCTION;
	sprintf(T_pOp_code.arr, "%d",pOp_code ); 
	T_pOp_code.len = 4;
	
	EXEC SQL WHENEVER SQLERROR GOTO err_UbpInquiry;
	EXEC SQL EXECUTE
	BEGIN 
	:response_code := PCRD_UBP_TOOLS.GET_UTILITY_BY_OC(	:pAcqBank , 
	:plProfileCode,
	:T_pOp_code,
	:pMaster_idx,
	:T_pUtility_id ); 
	END; 
	END-EXEC;
	
	if( response_code == OK ) 
	{
		memcpy(pUtility_id, T_pUtility_id.arr, T_pUtility_id.len);
	}


	sprintf(sLine,"End get_utility_by_oc (len:%d: Utility_id:[%s])", T_pUtility_id.len,pUtility_id);
	trace_event(sLine,PROCESSING);
	return(response_code);

	err_UbpInquiry :
	EXEC SQL WHENEVER SQLERROR CONTINUE;
	
	sprintf(sLine, "%.40s",sqlca.sqlerrm.sqlerrmc);
	trace_event (  sLine , ERROR );
	trace_event("End get_utility_by_oc (SYSTEM_MALFUNCTION)", PROCESSING);
	trace_event("DETAILS", PROCESSING);
	
	return( SYSTEM_MALFUNCTION );
}




/*-------------GENERIC UBP ENQUIRY---------*/

int UbpInquiry_Serv  ( int nIndiceCtx , char *sTlvBuffer )
{
	struct sqlca sqlca;
	char sLine 		 [ MAX_LINE_TRC];

	EXEC SQL BEGIN DECLARE SECTION;
	VARCHAR   	T_tlv_bal	  [ LG_MAX + 1];
	int		    response_code;
	EXEC SQL END DECLARE SECTION;

	EXEC SQL CONTEXT USE :tab_ParamCtx[nIndiceCtx].ctx;

	trace_event ( "Start UbpInquiry_Serv () ", PROCESSING );

	return OK;
	/****************************************************************************/
	/*      INITIALISATION                                                      */
	/****************************************************************************/

	memset ( T_tlv_bal.arr            ,  0  ,   sizeof(T_tlv_bal.arr )  );
	T_tlv_bal.len = 0;


	/*PADSS*/
	P7_DB_PREPROC_TLV_BUF(sTlvBuffer)

	memcpy ( T_tlv_bal.arr     ,  sTlvBuffer   ,   strlen(sTlvBuffer )  );
	T_tlv_bal.len = strlen(sTlvBuffer );


	/****************************************************************************/
	/*      Appel PL/SQL                                                       */
	/****************************************************************************/
	response_code = SYSTEM_MALFUNCTION;
	EXEC SQL WHENEVER SQLERROR GOTO err_Ubp;
	EXEC SQL EXECUTE
	BEGIN

	:response_code := PCRD_UBP_WEB_SERVICES.UTILITY_ENQUIRY(  :T_tlv_bal  ); 
	
	END;
	END-EXEC;
	
	tlvcpy( sTlvBuffer , T_tlv_bal.arr, T_tlv_bal.len);
	memset ( T_tlv_bal.arr            ,  0  ,   sizeof(T_tlv_bal.arr )  );
	/*PADSS*/
	P7_DB_POSTPROC_TLV_BUF(sTlvBuffer)

	sprintf(sLine,"End UbpInquiry_Serv (%d)", response_code);
	trace_event(sLine,PROCESSING);
	return(response_code);

	err_Ubp :
	EXEC SQL WHENEVER SQLERROR CONTINUE;
	tlvcpy( sTlvBuffer , T_tlv_bal.arr, T_tlv_bal.len);
	memset ( T_tlv_bal.arr            ,  0  ,   sizeof(T_tlv_bal.arr )  );
	/*PADSS*/
	P7_DB_EXCP_POSTPROC_TLV_BUF(sTlvBuffer)

	sprintf(sLine, "%.40s",sqlca.sqlerrm.sqlerrmc);
	trace_event (  sLine , ERROR );
	trace_event("End UbpInquiry_Serv (SYSTEM_MALFUNCTION)", PROCESSING);
	return( SYSTEM_MALFUNCTION );
}/* End UbpInquiry_Serv */



