***********************************************************************/
int	UpdateDecTrans(
					int			nIndexCtx,
					char		*pTerminal,
					char		*pAcqBank,
					char		*pActionCode,
					char		*pAmount,
					char		*pCurrency,
					char		*pTrnDate,
					char		*pTrsDate)
{
	struct sqlca sqlca;
	char		sLine	[80];
	EXEC SQL BEGIN DECLARE SECTION;
	VARCHAR		hTerminal	[15 + 1];
	VARCHAR		hAcqBank	[6+1];/*ICH270715*/ 
	char		hCurrency	[ 3 + 1];
	char		hTrnDate	[12 + 1];
	char		hTrsDate	[10 + 1];
	char		hActionCode	[ 3 + 1];
	double		hAmount;
	int			hRetour;
	EXEC SQL END DECLARE SECTION;

	sprintf(sLine, "Start UpdateAppTrans(%.15s,%.6s,%.3s,%.12s,%.3s,%.12s,%.10s)",
		pTerminal,pAcqBank/*ICH270715*/,pActionCode,pAmount,pCurrency,pTrnDate,pTrsDate);
	trace_event(sLine, PROCESSING);

	/* - memset des buffer ---------------------------------------------- */
	memset(hTerminal.arr,	0, sizeof(hTerminal.arr));
	memset(hAcqBank.arr,	0, sizeof(hAcqBank.arr));/*ICH270715*/
	memset(hCurrency,		0, sizeof(hCurrency)	);
	memset(hTrnDate,		0, sizeof(hTrnDate)	);
	memset(hTrsDate,		0, sizeof(hTrsDate)	);
	memset(hActionCode,		0, sizeof(hActionCode)	);


	/* - initialisation des variables ----------------------------------- */
	memcpy(hTerminal.arr,	pTerminal, strlen(pTerminal));
	hTerminal.len	= strlen(pTerminal);

	memcpy(hAcqBank.arr,	pAcqBank, strlen(pAcqBank));/*ICH270715*/
	hAcqBank.len	= strlen(pAcqBank);

	memcpy(hCurrency,		pCurrency, strlen(pCurrency));

	memcpy(hTrnDate,		pTrnDate, strlen(pTrnDate));

	memcpy(hTrsDate,		pTrsDate, strlen(pTrsDate));

	memcpy(hActionCode,		pActionCode, strlen(pActionCode));

	hAmount = atof(pAmount);
	adjust_amount_numeric(nIndexCtx,&hAmount, hCurrency);


	/* - capture des exceptions ------------------------------------------ */
	EXEC SQL WHENEVER SQLERROR GOTO updateDecTransErr;
	EXEC SQL CONTEXT USE :tab_ParamCtx[nIndexCtx].ctx;

	/* - traitement PL/SQL ----------------------------------------------- */
	EXEC SQL EXECUTE
		BEGIN
		:hRetour := PCRD_ATM_ACTIVITY.UPDATE_DEC_TRANS(  :hTerminal,
		:hAcqBank,/*ICH270715*/  
		:hActionCode,/*ICH20190522*/
		:hAmount,
		:hCurrency,
		TO_DATE(:hTrnDate, 'YYMMDDHH24MISS'),
		TO_DATE(:hTrsDate, 'MMDDHH24MISS'));
	END;
	END-EXEC;

	if(hRetour != OK)
	{
		sprintf(sLine, "End   UpdateDecTrans(NOK)");
		trace_event(sLine, PROCESSING);
		return (NOK);
	}

	sprintf(sLine, "End   UpdateDecTrans(OK)");
	trace_event(sLine, PROCESSING);
	return (OK);

updateDecTransErr :
	sprintf(sLine, "%.79s", sqlca.sqlerrm.sqlerrmc);
	trace_event(sLine, ERROR);
	trace_event("End   UpdateDecTrans(ERROR)", ERROR);
	return (ERROR);
}

