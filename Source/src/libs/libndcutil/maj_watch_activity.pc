***********************************************************************/
int     UpdateDecBillPayment(
							int             nIndexCtx,
							char            *pTerminal,
							char			*pAcqBank,
							char			*pActionCode,
							char            *pAmount,
							char            *pTrnDate,
							char            *pTrsDate)
{
	struct sqlca sqlca;
	char            sLine   [80];
	EXEC SQL BEGIN DECLARE SECTION;
	VARCHAR             hTerminal       [15 + 1];
	VARCHAR				hAcqBank		[6+1];/*ICH270715*/
	char                hTrnDate        [12 + 1];
	char                hTrsDate        [10 + 1];
	char                hActionCode     [3 + 1];
	double              hAmount;
	int                 hRetour;
	EXEC SQL END DECLARE SECTION;

	sprintf(sLine, "Start UpdateDecBillPayment(%.15s,%.6s,%.3s,%.12s,%.12s,%.10s)",
		pTerminal,pAcqBank/*ICH270715*/,pActionCode,pAmount,pTrnDate,pTrsDate);
	trace_event(sLine, PROCESSING);

