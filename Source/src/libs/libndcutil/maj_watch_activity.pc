/***********************************************************************
**  nom	: GetWatchWarningJournal()					**
**  desc	: chargement de la commande pour le GAB			**
**  entree	: fTerminalNumber	-> numero du terminal		**
**  sortie	: fCommand		-> commande pour le terminal	**
**		  fPurgeDate		-> date d'expiration de la cmd	**
**  retour	: OK	-> si c'est OK					**
**		  ERROR	-> erreur fatal					**
**			(c) 1999 Hightech Payment Systems		**
***********************************************************************/
int	GetWatchWarningJournal(int 		nIndexCtx,char		*pTermNbr,char		*pAcqBank)
{
	struct sqlca sqlca;
	char  sLine[MAX_LINE_TRC];
	EXEC SQL BEGIN DECLARE SECTION;
	varchar		hTermNbr		[15+1];
	VARCHAR		hAcqBank	        [6+1];/*ICH270715*/
	char		hlog_printer_status	[1+1];
	int			hRet;
	EXEC SQL END DECLARE SECTION;

	sprintf(sLine, "Start GetWatchWarningJournal(%.15s,%.6s)", pTermNbr,pAcqBank/*ICH270715*/);
	trace_event(sLine, PROCESSING);

	/* - initilialisation des variables ------------------------------------- */
	memset(hTermNbr.arr,		0, sizeof(hTermNbr.arr)		  );
	memset(hAcqBank.arr,	0, sizeof(hAcqBank.arr));/*ICH270715*/
	memset(hlog_printer_status,		0, sizeof(hlog_printer_status)		  );
	hTermNbr.len	= sizeof(hTermNbr.arr);

	/* - renseignement des variables PL/SQL --------------------------------- */
	memcpy(hTermNbr.arr,pTermNbr, strlen(pTermNbr));
	hTermNbr.len	= strlen(pTermNbr);

	memcpy(hAcqBank.arr,	pAcqBank, strlen(pAcqBank));/*ICH270715*/
	hAcqBank.len	= strlen(pAcqBank);

	/* - capture des exceptions PL/SQL -------------------------------------- */
	EXEC SQL CONTEXT USE :tab_ParamCtx[nIndexCtx].ctx;
	EXEC SQL WHENEVER SQLERROR GOTO getUserCommandErr;

	/* - execution du traitement PL/SQL ------------------------------------- */
	EXEC SQL EXECUTE
		DECLARE
		enr_terminal_atm_watch_warning	TERMINAL_ATM_WATCH_WARNING%ROWTYPE;
	BEGIN
		-- preparation de l'enregistrement

		:hRet := PCRD_ATM_TOOLS.GET_ATM_WATCH_WARNING(:hTermNbr,:hAcqBank/*ICH270715*/,enr_terminal_atm_watch_warning);

		-- recuperation du resultat
		IF :hRet = DECLARATION_CST.OK
		THEN
			:hlog_printer_status :=enr_terminal_atm_watch_warning.log_printer_status;
		END IF;
	END;
	END-EXEC;

	/* - examen du retour du traitement PL/SQL ------------------------------ */
	if (hRet != OK)
	{
		sprintf(sLine, "End   GetWatchWarningJournal(%d)", hRet);
		trace_event(sLine, PROCESSING);
		return (hRet);
	}

	if ( memcmp(hlog_printer_status,"O",1) == 0 ) {
		sprintf(sLine, "End   GetWatchWarningJournal(NOK %s)", hlog_printer_status);
		trace_event(sLine, PROCESSING);
		return(NOK);
	}
	else
	{
		sprintf(sLine, "End   GetWatchWarningJournal(OK %s)", hlog_printer_status);
		trace_event(sLine, PROCESSING);
		return(OK);
	}

getUserCommandErr:
	sprintf(sLine, "%.79s", sqlca.sqlerrm.sqlerrmc);
	trace_event(sLine, ERROR);
	trace_event("End   GetWatchWarningJournal(ERROR)", ERROR);
	return (ERROR);
}
/***********************************************************************
**  nom	: GetWatchWarningTicket()				**
**  desc	: Get Status de Ticket 					**
**  retour	: OK	-> si c'est OK					**
**		  ERROR	-> erreur fatal					**
**			(c) 1999 Hightech Payment Systems		**
***********************************************************************/
int	GetWatchWarningTicket(int 		nIndexCtx,char		*pTermNbr,char		*pAcqBank)
{
	struct sqlca sqlca; /*MK 060606*/
	char  sLine[MAX_LINE_TRC];
	EXEC SQL BEGIN DECLARE SECTION;
	varchar		hTermNbr		[15+1];
	VARCHAR		hAcqBank		[6+1];/*ICH270715*/ 
	char		hticket_printer_status	[1+1];
	int			hRet;
	EXEC SQL END DECLARE SECTION;

	sprintf(sLine, "Start GetWatchWarningTicket(%.15s)", pTermNbr);
	trace_event(sLine, PROCESSING);

	/* - initilialisation des variables ------------------------------------- */
	memset(hTermNbr.arr,		0, sizeof(hTermNbr.arr)		  );
	memset(hAcqBank.arr,	0, sizeof(hAcqBank.arr));/*ICH270715*/
	memset(hticket_printer_status,		0, sizeof(hticket_printer_status)		  );
	hTermNbr.len	= sizeof(hTermNbr.arr);

	/* - renseignement des variables PL/SQL --------------------------------- */
	memcpy(hTermNbr.arr,pTermNbr, strlen(pTermNbr));
	hTermNbr.len	= strlen(pTermNbr);

	memcpy(hAcqBank.arr,	pAcqBank, strlen(pAcqBank));/*ICH270715*/
	hAcqBank.len	= strlen(pAcqBank);

	/* - capture des exceptions PL/SQL -------------------------------------- */
	EXEC SQL CONTEXT USE :tab_ParamCtx[nIndexCtx].ctx;
	EXEC SQL WHENEVER SQLERROR GOTO getUserCommandErr;

	/* - execution du traitement PL/SQL ------------------------------------- */
	EXEC SQL EXECUTE
		DECLARE
		enr_terminal_atm_watch_warning	TERMINAL_ATM_WATCH_WARNING%ROWTYPE;
	BEGIN
		-- preparation de l'enregistrement

		:hRet := PCRD_ATM_TOOLS.GET_ATM_WATCH_WARNING(:hTermNbr,:hAcqBank/*ICH270715*/,enr_terminal_atm_watch_warning);

		-- recuperation du resultat
		IF :hRet = DECLARATION_CST.OK
		THEN
			:hticket_printer_status :=enr_terminal_atm_watch_warning.TICKET_PRINTER_STATUS;
		END IF;
	END;
	END-EXEC;

	/* - examen du retour du traitement PL/SQL ------------------------------ */
	if (hRet != OK)
	{
		sprintf(sLine, "End   GetWatchWarningTicket(%d)", hRet);
		trace_event(sLine, PROCESSING);
		return (hRet);
	}

	if ( memcmp(hticket_printer_status,"O",1) == 0 ) {
		sprintf(sLine, "End   GetWatchWarningTicket(NOK %s)", hticket_printer_status);
		trace_event(sLine, PROCESSING);
		return(NOK);
	}
	else
	{
		sprintf(sLine, "End   GetWatchWarningTicket(OK %s)", hticket_printer_status);
		trace_event(sLine, PROCESSING);
		return(OK);
	}

getUserCommandErr:
	sprintf(sLine, "%.79s", sqlca.sqlerrm.sqlerrmc);
	trace_event(sLine, ERROR);
	trace_event("End   GetWatchWarningTicket(ERROR)", ERROR);
	return (ERROR);
}

int	GetWatchActivity( int nIndiceCtx, char *sTlvBuffer)
{
	struct sqlca sqlca;
	char sLine	[MAX_LINE_TRC];

	EXEC SQL BEGIN DECLARE SECTION;
 	VARCHAR   	T_tlv_auth	 [ LG_MAX + 1];
	int			response_code;
	EXEC SQL END DECLARE SECTION;

	sprintf(sLine, "Start GetWatchActivity() ");
	trace_event(sLine, PROCESSING);

	EXEC SQL CONTEXT USE :tab_ParamCtx[nIndiceCtx].ctx;

	memset ( T_tlv_auth.arr            ,0    ,   sizeof(T_tlv_auth.arr )  );
	T_tlv_auth.len = 0;

	/*PADSS*/
	P7_DB_PREPROC_TLV_BUF(sTlvBuffer)

	memcpy ( T_tlv_auth.arr     ,  sTlvBuffer   ,   strlen(sTlvBuffer )  );
	T_tlv_auth.len = strlen(sTlvBuffer );

	response_code = SYSTEM_MALFUNCTION;
	EXEC SQL WHENEVER SQLERROR GOTO GetWatchActivityErr;

	/* - traitement PL/SQL ----------------------------------------------- */
	EXEC SQL EXECUTE
	BEGIN
		:response_code := PCRD_ATM_ACTIVITY.GET_WATCH_ACTIVITY (:T_tlv_auth);
		
	END;
	END-EXEC;

	tlvcpy( sTlvBuffer , T_tlv_auth.arr, T_tlv_auth.len);
	memset ( T_tlv_auth.arr, 0, sizeof ( T_tlv_auth.arr ));
	/*PADSS*/
	P7_DB_POSTPROC_TLV_BUF(sTlvBuffer)

	if(response_code != OK)
	{
		sprintf(sLine, "End   GetWatchActivity(NOK)");
		trace_event(sLine, PROCESSING);
		return (NOK);
	}

	sprintf(sLine, "End   GetWatchActivity(OK)");
	trace_event(sLine, PROCESSING);
	return (OK);

GetWatchActivityErr :
	EXEC SQL WHENEVER SQLERROR CONTINUE;
	tlvcpy( sTlvBuffer , T_tlv_auth.arr, T_tlv_auth.len);
	memset ( T_tlv_auth.arr, 0, sizeof ( T_tlv_auth.arr ));
	/*PADSS*/
	P7_DB_EXCP_POSTPROC_TLV_BUF(sTlvBuffer)
	sprintf(sLine, "%.79s", sqlca.sqlerrm.sqlerrmc);
	trace_event(sLine, ERROR);
	trace_event("End   GetWatchActivityErr(ERROR)", ERROR);
	return (SYSTEM_MALFUNCTION);
}
