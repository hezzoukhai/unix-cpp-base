/***********************************************************************
**  nom	: UpdateAppExtTransfer()				**
**  desc	: maj des virements approuvees dans watch_activity	**
**  entree	: pTerminal	-> numero du terminal			**
**		  pAmount	-> montant vire				**
**		  pCurrency	-> monnaie du vire approuve		**
**		  pTrnDate	-> date de la transaction		**
**		  pTrsDate	-> dete de la transmission		**
**  sortie	: aucune						**
**  retour	: OK	-> si c'est OK					**
**		  NOK	-> Pb PL/SQL					**
**		  ERROR	-> erreur FATAL					**
**  auteur	: Younes OUADI (19 dec 1998)				**
***********************************************************************/
int	UpdateAppExtTransfer(
						int			nIndexCtx,
						char		*pTerminal,
						char		*pAcqBank,
						char		*pAmount,
						char		*pCurrency,
						char		*pTrnDate,
						char		*pTrsDate)
{
	struct sqlca sqlca;
	char		sLine	[80];
	EXEC SQL BEGIN DECLARE SECTION;
	VARCHAR		hTerminal	[15 + 1];
	VARCHAR		hAcqBank	[6+1];/*ICH270715*/   
	char		hCurrency	[ 3 + 1];
	char		hTrnDate	[12 + 1];
	char		hTrsDate	[10 + 1];
	double		hAmount;
	int			hRetour;
	EXEC SQL END DECLARE SECTION;

	sprintf(sLine, "Start UpdateAppExtTransfer(%.15s,%.6s,%.12s,%.3s,%.12s,%.10s)",
		pTerminal,pAcqBank/*ICH270715*/,pAmount,pCurrency,pTrnDate,pTrsDate);
	trace_event(sLine, PROCESSING);

	/* - memset des buffer ---------------------------------------------- */
	memset(hTerminal.arr,	0, sizeof(hTerminal.arr));
	memset(hAcqBank.arr,	0, sizeof(hAcqBank.arr));/*ICH270715*/
	memset(hCurrency,		0, sizeof(hCurrency)	);
	memset(hTrnDate,		0, sizeof(hTrnDate)	);
	memset(hTrsDate,		0, sizeof(hTrsDate)	);


	/* - initialisation des variables ----------------------------------- */
	memcpy(hTerminal.arr,	pTerminal, strlen(pTerminal));
	hTerminal.len	= strlen(pTerminal);

	memcpy(hAcqBank.arr,	pAcqBank, strlen(pAcqBank));/*ICH270715*/
	hAcqBank.len	= strlen(pAcqBank);

	memcpy(hCurrency,		pCurrency, strlen(pCurrency));

	memcpy(hTrnDate,		pTrnDate, strlen(pTrnDate));

	memcpy(hTrsDate,		pTrsDate, strlen(pTrsDate));

	hAmount = atof(pAmount);
	adjust_amount_numeric(nIndexCtx,&hAmount, hCurrency);


	/* - capture des exceptions ------------------------------------------ */
	EXEC SQL WHENEVER SQLERROR GOTO updateAppExtTransferErr;
	EXEC SQL CONTEXT USE :tab_ParamCtx[nIndexCtx].ctx;

	/* - traitement PL/SQL ----------------------------------------------- */
	EXEC SQL EXECUTE
		BEGIN
		:hRetour := PCRD_ATM_ACTIVITY.UPDATE_APP_EXT_TRANSFER(:hTerminal,
		:hAcqBank,/*ICH270715*/  
		:hAmount,
		:hCurrency,
		TO_DATE(:hTrnDate, 'YYMMDDHH24MISS'),
		TO_DATE(:hTrsDate, 'MMDDHH24MISS'));
	END;
	END-EXEC;

	if(hRetour != OK)
	{
		sprintf(sLine, "End   UpdateAppExtTransfer(NOK)");
		trace_event(sLine, PROCESSING);
		return (NOK);
	}

	sprintf(sLine, "End   UpdateAppExtTransfer(OK)");
	trace_event(sLine, PROCESSING);
	return (OK);

updateAppExtTransferErr :
	sprintf(sLine, "%.79s", sqlca.sqlerrm.sqlerrmc);
	trace_event(sLine, ERROR);
	trace_event("End   UpdateAppExtTransfer(ERROR)", ERROR);
	return (ERROR);
}

