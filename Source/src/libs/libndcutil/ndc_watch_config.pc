  /***********************************************************************
  **  nom	: UpdateInServiceFlag()					**
  **  desc	: maj du flag CMD_IN_SERVICE_FLAG			**
  **  entree	: pTermNbr	-> numero du terminal			**
  **		  pInServiceFlag-> nouvelle valeur du flag		**
  **  sortie	: aucune						**
  **  retour	: OK	-> si c'est OK					**
  **		  ERROR	-> erreur fatal					**
  **			(c) 1999 Hightech Payment Systems		**
  ***********************************************************************/
int	UpdateInServiceFlag(int 	nIndexCtx,char	*pTermNbr,char	*pAcqBank,char	*pInServiceFlag)
{
   struct sqlca sqlca;
   char  sLine[MAX_LINE_TRC];
EXEC SQL BEGIN DECLARE SECTION;
    varchar	hTermNbr		[15+1];
	VARCHAR	hAcqBank			[6+1];/*ICH270715*/ 	
    char	hInServiceFlag	[ 1+1];
    int		hRet;
EXEC SQL END DECLARE SECTION;

sprintf(sLine, "Start UpdateInServiceFlag(%.15s,%.6s,%.1s)",
                 pTermNbr,pAcqBank, pInServiceFlag);
trace_event(sLine, PROCESSING);

    memset(hTermNbr.arr,	0, sizeof(hTermNbr.arr));
    memset(hAcqBank.arr,	0, sizeof(hAcqBank.arr));/*ICH270715*/ 
    memset(hInServiceFlag,	0, sizeof(hInServiceFlag));

    memcpy(hInServiceFlag,	pInServiceFlag, strlen(pInServiceFlag)	);
    memcpy(hTermNbr.arr,	pTermNbr, 	strlen(pTermNbr)	);
    hTermNbr.len		= strlen(pTermNbr);
    memcpy(hAcqBank.arr,	pAcqBank, strlen(pAcqBank));
    hAcqBank.len	= strlen(pAcqBank);

    EXEC SQL WHENEVER SQLERROR GOTO updateInServiceFlagErr;
    EXEC SQL CONTEXT USE :tab_ParamCtx[nIndexCtx].ctx;

    EXEC SQL EXECUTE
    BEGIN
        :hRet := PCRD_NDC_WATCH_CONFIG.UPDATE_IN_SERVICE_FLAG(:hTermNbr,
							:hAcqBank/*ICH270715*/,
							:hInServiceFlag);
    END;
    END-EXEC;

    if(hRet != OK)
    {
        sprintf(sLine, "End   UpdateInServiceFlag(%d)", hRet);
        trace_event(sLine, PROCESSING);
        return (NOK);
    }

sprintf(sLine, "End   UpdateInServiceFlag(OK)");
trace_event(sLine, PROCESSING);
return (OK);

updateInServiceFlagErr:
    sprintf(sLine, "%.79s", sqlca.sqlerrm.sqlerrmc);
    trace_event(sLine, ERROR);
    trace_event("End   UpdateInServiceFlag(ERROR)", ERROR);
    return (ERROR);
}

